export const RUNTIME_NOTE_VIDEOS_DIR = `${RUNTIME_VIDEOS_DIR}/note`
export const RUNTIME_MUSIC_DIR = `${RUNTIME_ASSETS_DIR}/music`
export const RUNTIME_NOTE_DOCS_DIR = `${RUNTIME_ASSETS_DIR}/note_docs`

