/**
 * 注意：项目根目录的 assets/ 只是“逻辑分层目录”。
 * 运行时可写目录必须使用沙箱路径（USER_DATA_PATH）。
 * 去除末尾斜杠以避免 // 路径问题
 */
const _ROOT_BASE = uni.env.USER_DATA_PATH.replace(/\/+$/, '')
export const RUNTIME_ROOT_DIR = `${_ROOT_BASE}/zemo`
export const RUNTIME_ASSETS_DIR = `${RUNTIME_ROOT_DIR}/assets`

export const RUNTIME_IMAGES_DIR = `${RUNTIME_ASSETS_DIR}/images`
