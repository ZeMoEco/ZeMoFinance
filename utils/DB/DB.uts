// utils/db/db.uts

// #ifdef APP-ANDROID
import SQLiteDatabase from 'android.database.sqlite.SQLiteDatabase'
import Cursor from 'android.database.Cursor'
import UTSAndroid from 'io.dcloud.uts.UTSAndroid'
// #endif

// #ifdef APP-HARMONY
import relationalStore from '@ohos.data.relationalStore'
// #endif

import { getCurrentAppId, getCurrentDbName } from '../app/AppRuntime.uts'
import { LOCAL_SYNC_DIRTY_EVENT } from '../constant.uts'

export type SqlValue = string | number | boolean | null
export type SqlArgs = Array<SqlValue>
export type Row = Map<string, any | null>

export type MergeByUpdatedAtOptions = {
  primaryKey?: string
  updatedAtColumn?: string
}

export type ColumnDef = {
  name: string
  type: string
  notNull?: boolean
  primaryKey?: boolean
  autoIncrement?: boolean
  unique?: boolean
  default?: string | number | boolean | null
}

export type IndexDef = {
  name: string
  columns: string[]
  unique?: boolean
}

export type TableDef = {
  name: string
  columns: ColumnDef[]
  indexes?: IndexDef[]
}

export type ModuleSchema = {
  name: string
  tables: TableDef[]
}

type DriverKind = 'android' | 'harmony' | 'ios' | 'unknown'

interface ISqlDriver {
  kind: DriverKind
  init(context: any | null, dbName: string): Promise<boolean>
  getDatabasePath(): string
  exec(sql: string, args?: SqlArgs | null): Promise<boolean>
  query(sql: string, args?: SqlArgs | null): Promise<Row[]>
  beginTransaction(): Promise<void>
  setTransactionSuccessful(): Promise<void>
  endTransaction(): Promise<void>
  close(): void
}

function createSyncMetadataColumns(): ColumnDef[] {
  return [
    { name: 'origin_app_id', type: 'TEXT', notNull: true, default: getCurrentAppId() },
    { name: 'entity_version', type: 'INTEGER', notNull: true, default: 1 },
    { name: 'tombstone_at', type: 'INTEGER' },
    { name: 'last_event_id', type: 'TEXT' },
  ]
}

function withSyncMetadata(columns: ColumnDef[]): ColumnDef[] {
  const out = [] as ColumnDef[]
  for (let i = 0; i < columns.length; i++) {
    out.push(columns[i])
  }
  const extras = createSyncMetadataColumns()
  for (let i = 0; i < extras.length; i++) {
    out.push(extras[i])
  }
  return out
}

class AndroidSqliteDriver implements ISqlDriver {
  kind: DriverKind = 'android'
  private dbName: string = 'ZeMo.db'
  private db: SQLiteDatabase | null = null
  private transactionSuccess: boolean = false

  async init(context: any | null, dbName: string): Promise<boolean> {
    this.dbName = dbName
    try {
      const appContext = UTSAndroid.getAppContext()
      if (appContext == null) return false
      const dbPath = appContext.getDatabasePath(this.dbName).getAbsolutePath()
      this.db = SQLiteDatabase.openOrCreateDatabase(dbPath, null)
      return this.db != null && this.db!.isOpen()
    } catch (e) {
      console.error(`[DB] Android init error: ${e}`)
      return false
    }
  }

  getDatabasePath(): string {
    try {
      const context = UTSAndroid.getAppContext()
      if (context == null) return ''
      return context.getDatabasePath(this.dbName).getAbsolutePath()
    } catch (_e) {
      return ''
    }
  }

  async exec(sql: string, args: SqlArgs | null): Promise<boolean> {
    if (this.db == null || !this.db!.isOpen()) return false
    try {
      const safeArgs = DB.normalizeArgs(args)
      if (safeArgs.length > 0) this.db!.execSQL(sql, safeArgs.toTypedArray())
      else this.db!.execSQL(sql)
      return true
    } catch (e) {
      console.error(`[DB] Android exec error: ${e} | SQL: ${sql}`)
      return false
    }
  }

  async query(sql: string, args: SqlArgs | null): Promise<Row[]> {
    const result: Row[] = []
    if (this.db == null || !this.db!.isOpen()) return result
    let cursor: Cursor | null = null
    try {
      const safeArgs: Array<any | null> = DB.normalizeArgs(args)
      const strArgs: Array<string> = []
      for (let i = 0; i < safeArgs.length; i++) {
        const item: any | null = safeArgs[i]
        strArgs.push(item != null ? item.toString() : '')
      }
      cursor = this.db!.rawQuery(sql, strArgs.length > 0 ? strArgs.toTypedArray() : null)
      if (cursor != null && cursor.moveToFirst()) {
        const colCount = cursor.getColumnCount()
        do {
          const row = new Map<string, any | null>()
          for (let i = 0; i < colCount; i++) {
            const idx = i.toInt()
            const name = cursor.getColumnName(idx)
            const type = cursor.getType(idx)
            if (type == Cursor.FIELD_TYPE_NULL) row.set(name, null)
            else if (type == Cursor.FIELD_TYPE_INTEGER) row.set(name, cursor.getLong(idx))
            else if (type == Cursor.FIELD_TYPE_FLOAT) row.set(name, cursor.getDouble(idx))
            else row.set(name, cursor.getString(idx))
          }
          result.push(row)
        } while (cursor.moveToNext())
      }
    } catch (e) {
      console.error(`[DB] Android query error: ${e} | SQL: ${sql}`)
    } finally {
      if (cursor != null) cursor.close()
    }
    return result
  }

  async beginTransaction(): Promise<void> {
    this.transactionSuccess = false
    if (this.db != null && this.db!.isOpen()) this.db!.beginTransaction()
  }

  async setTransactionSuccessful(): Promise<void> {
    this.transactionSuccess = true
    if (this.db != null && this.db!.isOpen()) this.db!.setTransactionSuccessful()
  }

  async endTransaction(): Promise<void> {
    if (this.db != null && this.db!.isOpen()) this.db!.endTransaction()
    this.transactionSuccess = false
  }

  close(): void {
    if (this.db != null) {
      try {
        if (this.db!.isOpen()) this.db!.close()
      } catch (_e) {}
    }
    this.db = null
  }
}

class UnknownDriver implements ISqlDriver {
  kind: DriverKind = 'unknown'

  async init(context: any | null, _dbName: string): Promise<boolean> {
    console.error('[DB] Unsupported platform')
    return false
  }

  getDatabasePath(): string {
    return ''
  }

  async exec(_sql: string, _args: SqlArgs | null): Promise<boolean> {
    return false
  }

  async query(_sql: string, _args: SqlArgs | null): Promise<Row[]> {
    return []
  }

  async beginTransaction(): Promise<void> {}
  async setTransactionSuccessful(): Promise<void> {}
  async endTransaction(): Promise<void> {}
  close(): void {}
}

class HarmonyRdbDriver implements ISqlDriver {
  kind: DriverKind = 'harmony'
  private dbName: string = 'ZeMo.db'
  private store: relationalStore.RdbStore | null = null
  private transactionSuccess: boolean = false
  private ctx: any | null = null

  async init(context: any | null, dbName: string): Promise<boolean> {
    this.dbName = dbName
    if (context == null) {
      console.error('[DB] Harmony init requires UIAbilityContext')
      return false
    }
    try {
      this.ctx = context as any
      const config: relationalStore.StoreConfig = {
        name: this.dbName,
        securityLevel: relationalStore.SecurityLevel.S1,
      }
      this.store = await relationalStore.getRdbStore(this.ctx, config)
      return this.store != null
    } catch (e) {
      const err = e as any
      console.error(`[DB] Harmony init error: ${err.code} - ${err.message}`)
      return false
    }
  }

  getDatabasePath(): string {
    try {
      if (this.ctx == null) return ''
      return `${this.ctx.databaseDir}/rdb/${this.dbName}`
    } catch (_e) {
      return ''
    }
  }

  async exec(sql: string, args: SqlArgs | null): Promise<boolean> {
    if (this.store == null) return false
    try {
      const safeArgs = DB.normalizeArgs(args)
      if (safeArgs.length > 0) await this.store!.executeSql(sql, safeArgs as Array<any>)
      else await this.store!.executeSql(sql)
      return true
    } catch (e) {
      const err = e as any
      if (sql.includes('ADD COLUMN') && err.code == 14800021) return true
      console.error(`[DB] Harmony exec error: ${err.code} - ${err.message} | SQL: ${sql}`)
      return false
    }
  }

  async query(sql: string, args: SqlArgs | null): Promise<Row[]> {
    const result: Row[] = []
    if (this.store == null) return result
    let rs: relationalStore.ResultSet | null = null
    try {
      const safeArgs = DB.normalizeArgs(args)
      if (safeArgs.length > 0) rs = await this.store!.querySql(sql, safeArgs as Array<any>)
      else rs = await this.store!.querySql(sql)
      if (rs != null && rs.rowCount > 0) {
        const colCount = rs.columnCount
        const colNames = rs.columnNames
        while (rs.goToNextRow()) {
          const row = new Map<string, any | null>()
          for (let i = 0; i < colCount; i++) {
            const name = colNames[i]
            if (rs.isColumnNull(i)) row.set(name, null)
            else row.set(name, rs.getString(i))
          }
          result.push(row)
        }
      }
    } catch (e) {
      const err = e as any
      console.error(`[DB] Harmony query error: ${err.code} - ${err.message} | SQL: ${sql}`)
    } finally {
      if (rs != null) rs.close()
    }
    return result
  }

  async beginTransaction(): Promise<void> {
    this.transactionSuccess = false
    if (this.store != null) this.store!.beginTransaction()
  }

  async setTransactionSuccessful(): Promise<void> {
    this.transactionSuccess = true
  }

  async endTransaction(): Promise<void> {
    if (this.store != null) {
      if (this.transactionSuccess) this.store!.commit()
      else this.store!.rollBack()
    }
    this.transactionSuccess = false
  }

  close(): void {
    this.store = null
    this.ctx = null
    this.transactionSuccess = false
  }
}

class PlusSqliteDriver implements ISqlDriver {
  kind: DriverKind = 'ios'
  private dbName: string = 'ZeMo.db'
  private transactionSuccess: boolean = false
  private opened: boolean = false
  private dbPath: string = ''

 async init(context: any | null, dbName: string): Promise<boolean> {
    this.dbName = dbName
    try {
      const g: any = globalThis as any
      const plusAny = g != null ? g.plus : null
      if (plusAny == null || plusAny.sqlite == null) {
        console.error('[DB] iOS sqlite driver not available (plus.sqlite missing)')
        return false
      }
      const basePath = (uni as any).env != null ? (uni as any).env.USER_DATA_PATH : ''
      this.dbPath = basePath ? `${basePath}/${this.dbName}` : this.dbName
      return await new Promise<boolean>((resolve) => {
        plusAny.sqlite.openDatabase({
          name: this.dbName,
          path: this.dbPath,
          success: () => {
            this.opened = true
            resolve(true)
          },
          fail: (e: any) => {
            console.error(`[DB] iOS openDatabase fail: ${JSON.stringify(e)}`)
            this.opened = false
            resolve(false)
          },
        })
      })
    } catch (e) {
      console.error(`[DB] iOS init error: ${e}`)
      return false
    }
  }

  getDatabasePath(): string {
    return this.dbPath
  }

  async exec(sql: string, args: SqlArgs | null): Promise<boolean> {
    try {
      const g: any = globalThis as any
      const plusAny = g != null ? g.plus : null
      if (plusAny == null || plusAny.sqlite == null || !this.opened) return false
      const rendered = DB.renderSql(sql, args)
      return await new Promise<boolean>((resolve) => {
        plusAny.sqlite.executeSql({
          name: this.dbName,
          sql: rendered,
          success: () => resolve(true),
          fail: (e: any) => {
            console.error(`[DB] iOS exec fail: ${JSON.stringify(e)} | SQL: ${rendered}`)
            resolve(false)
          },
        })
      })
    } catch (e) {
      console.error(`[DB] iOS exec error: ${e}`)
      return false
    }
  }

  async query(sql: string, args: SqlArgs | null): Promise<Row[]> {
    const result: Row[] = []
    try {
      const g: any = globalThis as any
      const plusAny = g != null ? g.plus : null
      if (plusAny == null || plusAny.sqlite == null || !this.opened) return result
      const rendered = DB.renderSql(sql, args)
      const rows = await new Promise<any[]>((resolve) => {
        plusAny.sqlite.selectSql({
          name: this.dbName,
          sql: rendered,
          success: (data: any[]) => resolve(data ?? []),
          fail: (e: any) => {
            console.error(`[DB] iOS query fail: ${JSON.stringify(e)} | SQL: ${rendered}`)
            resolve([])
          },
        })
      })
      for (let i = 0; i < rows.length; i++) {
        const obj = rows[i] as any
        const row = new Map<string, any | null>()
        try {
          if (obj != null && obj instanceof Map) {
            ;(obj as Map<string, any | null>).forEach((value: any | null, key: string) => {
              row.set(key, value ?? null)
            })
          }
        } catch (_e) {}
        result.push(row)
      }
    } catch (e) {
      console.error(`[DB] iOS query error: ${e}`)
    }
    return result
  }

  async beginTransaction(): Promise<void> {
    this.transactionSuccess = false
    await this.exec('BEGIN')
  }

  async setTransactionSuccessful(): Promise<void> {
    this.transactionSuccess = true
  }

  async endTransaction(): Promise<void> {
    if (this.transactionSuccess) await this.exec('COMMIT')
    else await this.exec('ROLLBACK')
    this.transactionSuccess = false
  }

  close(): void {
    try {
      const g: any = globalThis as any
      const plusAny = g != null ? g.plus : null
      if (plusAny != null && plusAny.sqlite != null && this.opened) {
        plusAny.sqlite.closeDatabase({ name: this.dbName })
      }
    } catch (_e) {}
    this.opened = false
  }
}

export class DB {
  private static _dbName: string = 'ZeMo.db'
  private static _driver: ISqlDriver | null = null
  private static _inited: boolean = false
  private static _lastInitContext: any | null = null
  private static _txDepth: number = 0
  private static _activeTransactionCount: number = 0
  private static _transactionMarkedSuccessful: boolean = false
  private static _pendingLocalSyncDirtyEvent: boolean = false

  static get schema(): ModuleSchema[] {
    return [
    {
      name: 'zemo_core',
      tables: [
        {
          name: 'nodes',
          columns: withSyncMetadata([
            { name: 'id', type: 'TEXT', primaryKey: true },
            { name: 'type', type: 'TEXT', notNull: true },
            { name: 'status', type: 'TEXT' },
            { name: 'content', type: 'TEXT' },
            { name: 'properties', type: 'TEXT' },
            { name: 'due_at', type: 'INTEGER' },
            { name: 'completed_at', type: 'INTEGER' },
            { name: 'created_at', type: 'INTEGER', notNull: true },
            { name: 'updated_at', type: 'INTEGER', notNull: true },
            { name: 'is_deleted', type: 'INTEGER', notNull: true, default: 0 },
          ]),
          indexes: [
            { name: 'idx_nodes_type_deleted_created', columns: ['type', 'is_deleted', 'created_at'] },
            { name: 'idx_nodes_updated_at', columns: ['updated_at'] },
            { name: 'idx_nodes_due_at', columns: ['due_at'] }
          ],
        },
        {
          name: 'edges',
          columns: withSyncMetadata([
            { name: 'id', type: 'TEXT', primaryKey: true },
            { name: 'source_id', type: 'TEXT', notNull: true },
            { name: 'target_id', type: 'TEXT', notNull: true },
            { name: 'relation_type', type: 'TEXT', notNull: true },
            { name: 'context_key', type: 'TEXT' },
            { name: 'status', type: 'TEXT', notNull: true, default: 'todo' },
            { name: 'secondary_category', type: 'TEXT' },
            { name: 'rank', type: 'TEXT', notNull: true, default: '500' },
            { name: 'properties', type: 'TEXT' },
            { name: 'created_at', type: 'INTEGER', notNull: true },
            { name: 'updated_at', type: 'INTEGER', notNull: true, default: 0 },
            { name: 'is_deleted', type: 'INTEGER', notNull: true, default: 0 },
          ]),
          indexes: [
            { name: 'idx_edges_source_relation_deleted', columns: ['source_id', 'relation_type', 'is_deleted'] },
            { name: 'idx_edges_relation_status_category_deleted', columns: ['relation_type', 'status', 'secondary_category', 'is_deleted'] },
            { name: 'idx_edges_source_relation_rank', columns: ['source_id', 'relation_type', 'is_deleted', 'rank'] },
            { name: 'idx_edges_target_relation', columns: ['target_id', 'relation_type', 'is_deleted'] },
            { name: 'idx_edges_unique_relation', columns: ['source_id', 'target_id', 'relation_type'], unique: true }
          ],
        },
        {
          name: 'users',
          columns: withSyncMetadata([
            { name: 'id', type: 'INTEGER', primaryKey: true, autoIncrement: true },
            { name: 'username', type: 'TEXT', notNull: true },
            { name: 'avatar', type: 'TEXT' },
            { name: 'xp', type: 'INTEGER', notNull: true, default: 0 },
            { name: 'level', type: 'INTEGER', notNull: true, default: 1 },
            { name: 'coins', type: 'INTEGER', notNull: true, default: 0 },
            { name: 'created_at', type: 'INTEGER', notNull: true },
            { name: 'updated_at', type: 'INTEGER', notNull: true },
          ]),
        },
        {
          name: 'accounts',
          columns: withSyncMetadata([
            { name: 'id', type: 'TEXT', primaryKey: true },
            { name: 'user_id', type: 'INTEGER', notNull: true, default: 1 },
            { name: 'name', type: 'TEXT', notNull: true },
            { name: 'type', type: 'TEXT', notNull: true },
            { name: 'balance', type: 'REAL', notNull: true, default: 0.0 },
            { name: 'currency', type: 'TEXT', notNull: true, default: 'CNY' },
            { name: 'category', type: 'TEXT', notNull: true, default: 'cash' },
            { name: 'card_no', type: 'TEXT' },
            { name: 'properties', type: 'TEXT' },
            { name: 'created_at', type: 'INTEGER', notNull: true },
            { name: 'updated_at', type: 'INTEGER', notNull: true, default: 0 },
            { name: 'is_deleted', type: 'INTEGER', notNull: true, default: 0 },
          ]),
          indexes: [
            { name: 'idx_accounts_user', columns: ['user_id', 'is_deleted'] },
            { name: 'idx_accounts_name', columns: ['name'] }
          ],
        },
        {
          name: 'transactions',
          columns: withSyncMetadata([
            { name: 'id', type: 'TEXT', primaryKey: true },
            { name: 'account_id', type: 'TEXT', notNull: true },
            { name: 'amount', type: 'REAL', notNull: true },
            { name: 'type', type: 'TEXT', notNull: true },
            { name: 'category', type: 'TEXT' },
            { name: 'description', type: 'TEXT' },
            { name: 'location', type: 'TEXT' },
            { name: 'transaction_time', type: 'INTEGER', notNull: true },
            { name: 'created_at', type: 'INTEGER', notNull: true },
            { name: 'updated_at', type: 'INTEGER', notNull: true, default: 0 },
            { name: 'balance_snapshot', type: 'REAL', default: 0.0 },
            { name: 'source_node_id', type: 'TEXT' },
            { name: 'item_node_id', type: 'TEXT' },
            { name: 'location_node_id', type: 'TEXT' },
            { name: 'properties', type: 'TEXT' },
            { name: 'is_deleted', type: 'INTEGER', notNull: true, default: 0 },
          ]),
          indexes: [
