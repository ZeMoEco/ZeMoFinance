<template>
<view class="record-modal-page">
<view class="record-backdrop" @click="closeSheet"></view>

<view class="record-sheet">
<view class="sheet-handle"></view>
<view class="sheet-close" @click="closeSheet">
<text class="sheet-close-icon">✕</text>
</view>

<view class="sheet-header">
<text class="sheet-title">{{ isEditMode ? '编辑账单' : '记账录入' }}</text>
<view class="header-options">
<view class="mini-toggle" :class="includeInFlow ? 'mini-toggle-active' : ''" @click="toggleIncludeInFlow">
<text class="mini-toggle-text" :class="includeInFlow ? 'mini-toggle-text-active' : ''">{{ includeInFlow ? '计收支' : '不计' }}</text>
</view>
<view class="mini-toggle" :class="isReimbursable ? 'mini-toggle-active' : ''" @click="toggleReimbursable">
<text class="mini-toggle-text" :class="isReimbursable ? 'mini-toggle-text-active' : ''">{{ isReimbursable ? '报销' : '未报' }}</text>
</view>
</view>
</view>

<view class="type-tabs">
<view
v-for="mode in modeTabs"
:key="mode"
					class="type-tab"
					:class="activeMode == mode ? 'type-tab-active' : ''"
@click="onModeTabClick(mode)">
					<text class="type-tab-text" :class="activeMode == mode ? 'type-tab-text-active' : ''">{{ getModeLabel(mode) }}</text>
</view>
</view>

<view class="amount-row">
				<text class="amount-sign" :class="financeType == 'income' ? 'amount-sign-income' : ''">{{ financeType == 'income' ? '+' : '-' }}</text>
<input
class="amount-input"
:class="amountInputClass"
type="text"
v-model="amount"
placeholder="0.00"
@input="onAmountInput"
/>
<view class="time-chip" @click="refreshTime">
<text class="time-chip-icon">🗓</text>
<text class="time-chip-text">{{ displayTime }}</text>
</view>
</view>

<view class="divider"></view>

<view class="info-row-grid" v-if="activeMode == 'expense' || activeMode == 'income'">
<view class="info-cell" @click="showTaskPicker">
<text class="info-label">项目任务</text>
<view class="info-select-pill">
<text class="info-select-icon">📋</text>
<text class="info-select-text">{{ selectedShoppingTaskName == '' ? '未选择' : selectedShoppingTaskName }}</text>
<text class="info-select-arrow">⌄</text>
</view>
</view>

<view class="info-cell" @click="showStoragePicker">
<text class="info-label">储存位置</text>
<view class="info-select-pill">
<text class="info-select-icon">🪣</text>
<text class="info-select-text">{{ selectedStorageTargetName == '' ? '未选择' : selectedStorageTargetName }}</text>
<text class="info-select-arrow">⌄</text>
</view>
</view>
</view>

<view class="refund-picker" v-if="activeMode == 'refund'">
<scroll-view class="refund-result-float" scroll-y="true" :show-scrollbar="false" v-if="selectedRefundTransactionId == '' && refundSearchText.trim() != ''">
<view
v-for="bill in filteredRefundBills"
:key="bill.id"
class="refund-result-item"
@click="selectRefundBill(bill)">
<text class="refund-result-main">{{ refundBillTitle(bill) }}</text>
<text class="refund-result-sub">{{ refundBillSubTitle(bill) }}</text>
</view>
<view class="refund-result-empty" v-if="filteredRefundBills.length == 0">
<text class="refund-result-empty-text">没有匹配账单</text>
</view>
</scroll-view>
<text class="refund-fill-label">退款账单</text>
<view class="refund-fill-row" v-if="selectedRefundTransactionId == ''">
<input class="refund-fill-input" v-model="refundSearchText" placeholder="输入账单关键词" />
<text class="refund-fill-arrow">⌄</text>
</view>
<view class="refund-fill-row refund-fill-selected" v-if="selectedRefundTransactionId != ''">
<view class="refund-fill-content">
<text class="refund-fill-main">{{ selectedRefundTransactionName }}</text>
<text class="refund-fill-sub">已关联原账单</text>
</view>
<text class="refund-fill-clear" @click.stop="clearRefundBill">×</text>
</view>
</view>

<view class="info-row-grid" v-if="activeMode == 'transfer'">
<view class="info-cell" @click="showTargetAccountPicker">
<text class="info-label">转入账户</text>
<view class="info-select-pill">
<text class="info-select-icon">🏦</text>
<text class="info-select-text">{{ selectedTargetAccountName }}</text>
<text class="info-select-arrow">⌄</text>
</view>
</view>
<view class="info-cell" @click="showAccountPicker">
<text class="info-label">转出账户</text>
<view class="info-select-pill">
<text class="info-select-icon">💳</text>
<text class="info-select-text">{{ selectedAccountName }}</text>
<text class="info-select-arrow">⌄</text>
</view>
</view>
</view>

<view class="category-header-row">
<text class="category-header">类别选择</text>
<view class="book-chip" @click="showBookPicker">
<text class="book-chip-text">{{ selectedBookName }}</text>
</view>
</view>

<scroll-view class="category-scroll" :class="categoryRows.length <= 1 ? 'category-scroll-one' : 'category-scroll-two'" scroll-y="true" :show-scrollbar="false">
<view class="category-list">
<view
v-for="(row, rowIndex) in categoryRows"
:key="'cat-row-' + rowIndex.toString()"
class="category-row">
<view
v-for="cat in row"
:key="cat.id"
class="category-item"
@click="selectCategory(cat.id)">
<view class="category-chip" :class="category == cat.id ? 'category-chip-active' : ''">
								<text class="category-icon">{{ cat.icon }}</text>
							</view>
<text class="category-text" :class="category == cat.id ? 'category-text-active' : ''">{{ cat.label }}</text>
</view>
</view>
</view>
</scroll-view>

<view class="note-card">
<view class="note-card-head">
<view class="note-account" @click="showAccountPicker">
<text class="note-left">{{ accountDisplayName }}</text>
<text class="note-account-arrow">⌄</text>
</view>
<view class="adjust-inputs">
<view class="adjust-field">
<text class="adjust-label">手续费</text>
<input class="adjust-input" type="text" v-model="serviceFee" placeholder="0" @input="onServiceFeeInput" />
</view>
<view class="adjust-field">
<text class="adjust-label">优惠券</text>
<input class="adjust-input" type="text" v-model="couponAmount" placeholder="0" @input="onCouponInput" />
</view>
</view>
</view>
<input class="note-input" v-model="note" placeholder="记录一条备注..." />
</view>

<view class="sheet-footer">
<button class="submit-btn" @click="submit">{{ isEditMode ? '保存修改 →' : '确认记账 →' }}</button>
<text class="delete-text" v-if="isEditMode" @click="deleteCurrentTransaction">{{ deletingTransaction ? '删除中...' : '删除账单' }}</text>
<text class="draft-text" v-if="!isEditMode">放弃录入</text>
</view>
</view>
</view>
</template>

<script lang="uts">
import { FinanceBiz, AccountNode, BookNode, TransactionMount, CreateTransactionForNodesPayload, UpdateTransactionPayload } from '@/services/biz/FinanceBiz.uts';
import { CreateStorageItemPayload, TaskBiz, Task } from '@/services/biz/TaskBiz.uts';
import { AutoFinanceService } from '@/services/sys/AutoFinanceService.uts';
import { FINANCE_APP_PROFILE } from '@/services/ecosystem/AppProfiles.uts';
import { EcosystemAppBootstrap } from '@/services/ecosystem/EcosystemAppBootstrap.uts';
import { AppBackgroundService } from '@/services/sys/AppBackgroundService.uts';
import { DESK_PET_RECORD_AUTO_BACKGROUND_PARAM } from '@/utils/constant.uts';
import { AppDialogApi } from '@/components/sys/AppDialogApi.uts';

type RecordMode = 'expense' | 'income' | 'transfer' | 'refund';
type CategoryItem = {
id : string
label : string
icon : string
}

export default {
data() {
return {
amount: '',
activeMode: 'income' as RecordMode,
category: 'income_salary',
note: '',
location: '',
includeInFlow: true,
isReimbursable: false,
serviceFee: '',
couponAmount: '',
refundSearchText: '',
refundCandidates: [] as TransactionMount[],
selectedRefundTransactionId: '',
selectedRefundTransactionName: '',
displayTime: '',
accounts: [] as AccountNode[],
selectedAccountId: '',
allTasks: [] as Task[],
shoppingCandidates: [] as Task[],
storageCandidates: [] as Task[],
selectedShoppingTaskIds: [] as string[],
selectedShoppingTaskName: '',
selectedTargetAccountId: '',
selectedStorageTargetId: '',
selectedStorageTargetName: '',
selectedBookId: '',
bookOptions: [] as BookNode[],
prefillAccountId: '',
prefillTransactionTime: 0,
editTransactionId: '',
editCategoryLabel: '',
editOriginalCategory: '',
categoryChanged: false,
deletingTransaction: false,
prefillSourceApp: '',
prefillPayMethod: '',
autoBackgroundAfterSubmit: false,
modeTabs: [
'expense',
'income',
'transfer',
'refund'
] as RecordMode[]
}
},
computed: {
financeType() : string {
if (this.activeMode == 'expense') return 'expense';
if (this.activeMode == 'income') return 'income';
if (this.activeMode == 'refund') return 'income';
return 'expense';
},
currentCategories() : CategoryItem[] {
if (this.activeMode == 'transfer') {
return [
{ id: 'transfer_general', label: '转账', icon: '⇄' },
{ id: 'transfer_fund', label: '基金', icon: '基' },
{ id: 'transfer_stock', label: '股票', icon: '股' },
{ id: 'transfer_security', label: '证券', icon: '券' },
{ id: 'transfer_finance_add', label: '加仓', icon: '↗' },
{ id: 'transfer_finance_reduce', label: '减仓', icon: '↘' }
];
}
if (this.activeMode == 'refund') {
return [
{ id: 'income_refund_extra', label: '退款', icon: '↩' },
{ id: 'income_reimburse', label: '报销', icon: '回' },
{ id: 'income_other', label: '其他', icon: '…' }
];
}
if (this.financeType == 'expense') {
return [
{ id: 'expense_tax', label: '可抵税', icon: '🧾' },
{ id: 'expense_shopping', label: '购物', icon: '🛍' },
{ id: 'expense_transport', label: '交通', icon: '↗' },
{ id: 'expense_gift', label: '礼金', icon: '🎁' },
{ id: 'expense_reward', label: '奖金', icon: '✦' },
{ id: 'expense_food', label: '餐饮', icon: '🍜' },
{ id: 'expense_home', label: '居家', icon: '⌂' },
{ id: 'expense_medical', label: '医疗', icon: '+' },
{ id: 'expense_study', label: '学习', icon: '书' },
{ id: 'expense_entertainment', label: '娱乐', icon: '♪' },
{ id: 'expense_other', label: '其他', icon: '…' }
];
}
return [
{ id: 'income_tax', label: '可抵税', icon: '🧾' },
{ id: 'income_salary', label: '工资', icon: '💵' },
{ id: 'income_gift', label: '礼金', icon: '🎁' },
{ id: 'income_reward', label: '奖金', icon: '✦' },
{ id: 'income_reimburse', label: '报销', icon: '回' },
{ id: 'income_parttime', label: '兼职', icon: '时' },
{ id: 'income_interest', label: '利息', icon: '%' },
{ id: 'income_rent', label: '租金', icon: '⌂' },
{ id: 'income_refund_extra', label: '退款', icon: '↩' },
{ id: 'income_other', label: '其他', icon: '…' }
];
},
filteredRefundBills() : TransactionMount[] {
const q = this.refundSearchText.trim().toLowerCase();
let list = this.refundCandidates;
if (q != '') {
list = list.filter((bill : TransactionMount) : boolean => {
const text = `${bill.description ?? ''} ${bill.category ?? ''} ${bill.account_name ?? ''} ${bill.amount.toString()}`.toLowerCase();
return text.indexOf(q) >= 0;
});
}
return list.slice(0, 20);
},
categoryRows() : CategoryItem[][] {
const rows = [] as CategoryItem[][];
const list = this.currentCategories;
for (let i = 0; i < list.length; i += 4) {
const row = [] as CategoryItem[];
for (let j = i; j < i + 4 && j < list.length; j++) {
row.push(list[j]);
}
rows.push(row);
}
return rows;
},
accountCandidates() : AccountNode[] {
if (this.activeMode == 'transfer') return this.accounts;
return this.accounts.filter((acc : AccountNode) : boolean => !this.isTransferOnlyAccount(acc));
},
categoryLabel() : string {
const found = this.currentCategories.find((c : CategoryItem) : boolean => c.id == this.category);
return found != null ? found.label : '';
},
amountInputClass() : string {
const len = this.amount.trim().length;
if (len >= 8) return 'amount-input-compact';
if (len >= 5) return 'amount-input-long';
return '';
},
selectedAccountName() : string {
if (this.selectedAccountId == '') return '选择账户';
const acc = this.accounts.find((a : AccountNode) : boolean => a.id == this.selectedAccountId);
if (acc == null) return '选择账户';
const name = (acc.name ?? '').toString().trim();
const base = name == '' ? '至尊账户' : name;
const raw = (acc.card_no ?? '').toString().trim();
if (raw == '') return base;
const tail = raw.length > 4 ? raw.substring(raw.length - 4) : raw;
return `${base} *${tail}`;
},
selectedTargetAccountName() : string {
if (this.selectedTargetAccountId == '') return '选择账户';
const acc = this.accounts.find((a : AccountNode) : boolean => a.id == this.selectedTargetAccountId);
if (acc == null) return '选择账户';
const name = (acc.name ?? '').toString().trim();
const base = name == '' ? '至尊账户' : name;
const raw = (acc.card_no ?? '').toString().trim();
if (raw == '') return base;
const tail = raw.length > 4 ? raw.substring(raw.length - 4) : raw;
return `${base} *${tail}`;
},
accountDisplayName() : string {
if (this.selectedAccountId == '') return '至尊账户';
const acc = this.accounts.find((a : AccountNode) : boolean => a.id == this.selectedAccountId);
if (acc == null) return '至尊账户';
const name = (acc.name ?? '').toString().trim();
const base = name == '' ? '至尊账户' : name;
const raw = (acc.card_no ?? '').toString().trim();
if (raw == '') return base;
const tail = raw.length > 4 ? raw.substring(raw.length - 4) : raw;
return `${base} *${tail}`;
},
selectedBookName() : string {
const b = this.bookOptions.find((x : BookNode) : boolean => x.id == this.selectedBookId);
return b != null ? b.name : '日常账本';
},
effectiveCategory() : string {
if (this.activeMode == 'transfer') return this.categoryLabel == '' ? '转账' : this.categoryLabel;
if (this.activeMode == 'refund') return '退款';
if (this.isEditMode && !this.categoryChanged && this.editOriginalCategory.trim() != '') return this.editOriginalCategory;
return this.categoryLabel;
},
isEditMode() : boolean {
return this.editTransactionId.trim() != '';
}
},
onLoad(options : OnLoadOptions) {
this.refreshTime();
let inferredModeFromAmount = '';

// Support prefilled parameters from OCR screen recognition
const editParam = options['editTransactionId'];
if (editParam != null) {
this.editTransactionId = editParam.toString();
}
if (this.editTransactionId.trim() == '') {
const cachedEditId = uni.getStorageSync(AppDialogApi.FINANCE_RECORD_EDIT_ID_KEY);
if (cachedEditId != null && cachedEditId.toString().trim() != '') {
this.editTransactionId = cachedEditId.toString();
}
}
const amountParam = options['amount'];
if (amountParam != null) {
const amountText = amountParam.toString();
const amountValue = parseFloat(amountText);
if (!isNaN(amountValue)) {
this.amount = Math.abs(amountValue).toString();
if (amountValue < 0) inferredModeFromAmount = 'expense';
} else {
this.amount = amountText.replace(/[^0-9.]/g, '');
}
}
const noteParam = options['note'];
if (noteParam != null) {
this.note = noteParam.toString();
}
const modeParam = options['activeMode'];
if (modeParam != null) {
const rawMode = modeParam.toString();
if (rawMode == 'expense' || rawMode == 'income' || rawMode == 'transfer' || rawMode == 'refund') this.activeMode = rawMode as RecordMode;
} else if (inferredModeFromAmount != '') {
this.activeMode = inferredModeFromAmount as RecordMode;
if (inferredModeFromAmount == 'expense') this.category = 'expense_tax';
}
const categoryParam = options['category'];
if (categoryParam != null) {
this.category = categoryParam.toString();
}
const categoryLabelParam = options['categoryLabel'];
if (categoryLabelParam != null) {
this.editCategoryLabel = categoryLabelParam.toString();
this.editOriginalCategory = this.editCategoryLabel;
}
const accountParam = options['accountId'];
if (accountParam != null) {
this.prefillAccountId = accountParam.toString();
}
const bookParam = options['bookId'];
if (bookParam != null) {
this.selectedBookId = bookParam.toString();
}
const transactionTimeParam = options['transactionTime'];
if (transactionTimeParam != null) {
const ts = parseFloat(transactionTimeParam.toString());
if (!isNaN(ts) && ts > 0) {
this.prefillTransactionTime = ts;
const d = new Date(ts);
const h = d.getHours().toString().padStart(2, '0');
const m = d.getMinutes().toString().padStart(2, '0');
this.displayTime = `${d.getFullYear()}-${(d.getMonth() + 1).toString().padStart(2, '0')}-${d.getDate().toString().padStart(2, '0')}, ${h}:${m}`;
}
}
const sourceAppParam = options['sourceApp'];
if (sourceAppParam != null) {
this.prefillSourceApp = sourceAppParam.toString();
}
const payMethodParam = options['payMethod'];
if (payMethodParam != null) {
this.prefillPayMethod = payMethodParam.toString();
}
const autoBgParam = options[DESK_PET_RECORD_AUTO_BACKGROUND_PARAM];
this.autoBackgroundAfterSubmit = autoBgParam != null && autoBgParam.toString() == '1';
this.loadBooks();
if (this.editTransactionId.trim() != '') {
this.loadEditingTransaction();
}
},
onShow() {
},
onBackPress() : boolean | null {
AppDialogApi.isRecordOpenGlobal = false;
uni.removeStorageSync(AppDialogApi.FINANCE_RECORD_EDIT_ID_KEY);
return false;
},
onUnload() {
AppDialogApi.isRecordOpenGlobal = false;
uni.removeStorageSync(AppDialogApi.FINANCE_RECORD_EDIT_ID_KEY);
},
watch: {
activeMode(newMode : RecordMode) {
if (this.isEditMode && this.editCategoryLabel.trim() != '') {
this.applyCategoryLabel(this.editCategoryLabel);
this.editCategoryLabel = '';
return;
}
if (newMode == 'income') {
this.category = 'income_salary';
} else if (newMode == 'expense') {
this.category = 'expense_tax';
} else if (newMode == 'transfer') {
this.category = 'transfer_general';
} else if (newMode == 'refund') {
this.category = 'income_refund_extra';
this.loadRefundCandidates();
}
this.ensureSelectedAccountAllowed();
},
selectedBookId(_newVal : string) {
this.loadAccounts();
}
},
methods: {
accountCardTail(acc : AccountNode) : string {
const raw = (acc.card_no ?? '').toString().trim();
if (raw == '') return '';
const tail = raw.length > 4 ? raw.substring(raw.length - 4) : raw;
return `*${tail}`;
},
accountDisplayText(acc : AccountNode) : string {
const name = (acc.name ?? '').toString().trim();
const base = name == '' ? '至尊账户' : name;
const tail = this.accountCardTail(acc);
return tail == '' ? base : `${base} ${tail}`;
},
isTransferOnlyAccount(acc : AccountNode) : boolean {
const category = (acc.category ?? '').toString().trim().toLowerCase();
const subType = (acc.sub_type ?? '').toString().trim();
const type = (acc.type ?? '').toString().trim();
const name = (acc.name ?? '').toString().trim();
const text = `${subType} ${type} ${name}`;
if (category == 'investment') return true;
return text.indexOf('基金') >= 0 || text.indexOf('股票') >= 0 || text.indexOf('证券') >= 0 || text.indexOf('ETF') >= 0;
},
ensureSelectedAccountAllowed() {
const candidates = this.accountCandidates;
if (candidates.length == 0) {
this.selectedAccountId = '';
return;
}
if (this.selectedAccountId == '' || candidates.find((a : AccountNode) : boolean => a.id == this.selectedAccountId) == null) {
this.selectedAccountId = candidates[0].id;
}
},
refundBillTitle(bill : TransactionMount) : string {
const desc = (bill.description ?? '').toString().trim();
const cat = (bill.category ?? '').toString().trim();
const title = desc != '' ? desc : (cat != '' ? cat : '未命名账单');
const sign = bill.type == 'income' ? '+' : '-';
return `${title} ${sign}${Math.abs(bill.amount).toFixed(2)}`;
},
refundBillSubTitle(bill : TransactionMount) : string {
const d = new Date(bill.transaction_time);
const dateText = `${(d.getMonth() + 1).toString().padStart(2, '0')}-${d.getDate().toString().padStart(2, '0')}`;
const account = (bill.account_name ?? '').toString().trim();
const cat = (bill.category ?? '').toString().trim();
return `${dateText} ${account == '' ? '未知账户' : account}${cat == '' ? '' : ' · ' + cat}`;
},
closeSheet() {
if (AppDialogApi.tryCloseDialog()) return;
uni.navigateBack();
},
getModeLabel(mode : RecordMode) : string {
if (mode == 'expense') return '支出';
if (mode == 'income') return '收入';
if (mode == 'transfer') return '转账';
if (mode == 'refund') return '退款';
return '支出';
},
onModeTabClick(mode : RecordMode) {
this.categoryChanged = true;
this.activeMode = mode;
if (mode == 'transfer') {
this.selectedShoppingTaskIds = [] as string[];
this.selectedShoppingTaskName = '';
this.selectedStorageTargetId = '';
this.selectedStorageTargetName = '';
if (this.accounts.length > 1 && this.selectedTargetAccountId == '') {
for (let i = 0; i < this.accounts.length; i++) {
if (this.accounts[i].id != this.selectedAccountId) {
this.selectedTargetAccountId = this.accounts[i].id;
break;
}
}
}
} else if (mode == 'refund') {
this.selectedShoppingTaskIds = [] as string[];
this.selectedShoppingTaskName = '';
this.selectedStorageTargetId = '';
this.selectedStorageTargetName = '';
this.loadRefundCandidates();
}
},
selectCategory(id : string) {
this.categoryChanged = true;
this.category = id;
},
async loadRefundCandidates() {
this.refundCandidates = await FinanceBiz.listRecentTransactions(80);
},
filterRefundBills(keyword : string) : TransactionMount[] {
const q = keyword.trim().toLowerCase();
let list = this.refundCandidates;
if (q != '') {
list = list.filter((bill : TransactionMount) : boolean => {
const text = `${bill.description ?? ''} ${bill.category ?? ''} ${bill.account_name ?? ''} ${bill.amount.toString()}`.toLowerCase();
return text.indexOf(q) >= 0;
});
}
return list.slice(0, 12);
},
selectRefundBill(bill : TransactionMount) {
this.selectedRefundTransactionId = bill.id;
this.selectedRefundTransactionName = this.refundBillTitle(bill);
this.amount = bill.amount.toString();
this.selectedAccountId = bill.account_id;
this.ensureSelectedAccountAllowed();
const desc = (bill.description ?? '').toString().trim();
this.note = desc == '' ? '退款' : `退款: ${desc}`;
},
clearRefundBill() {
this.selectedRefundTransactionId = '';
this.selectedRefundTransactionName = '';
this.refundSearchText = '';
},
refreshTime() {
const d = new Date();
const h = d.getHours().toString().padStart(2, '0');
const m = d.getMinutes().toString().padStart(2, '0');
this.displayTime = `今天, ${h}:${m}`;
},
toggleIncludeInFlow() {
this.includeInFlow = !this.includeInFlow;
},
toggleReimbursable() {
this.isReimbursable = !this.isReimbursable;
if (this.isReimbursable && this.activeMode == 'expense') {
this.category = 'expense_tax';
}
},
normalizeMoneyText(raw : string) : string {
let val = (raw ?? '').toString().replace(/[^0-9.]/g, '');
const dots = val.split('.').length - 1;
if (dots > 1) {
const firstDotIndex = val.indexOf('.');
val = val.substring(0, firstDotIndex + 1) + val.substring(firstDotIndex + 1).replace(/\./g, '');
}
if (val.includes('.')) {
const parts = val.split('.');
if (parts[1].length > 2) {
val = parts[0] + '.' + parts[1].substring(0, 2);
}
}
return val;
},
onServiceFeeInput(e : InputEvent) {
this.serviceFee = this.normalizeMoneyText(e.detail.value);
},
onCouponInput(e : InputEvent) {
this.couponAmount = this.normalizeMoneyText(e.detail.value);
},
moneyTextToNumber(raw : string) : number {
const val = parseFloat((raw ?? '').toString());
return isNaN(val) ? 0.0 : Math.abs(val);
},
applyTransactionProperties(raw : string | null) {
if (raw == null || raw.trim() == '') return;
try {
const props = JSON.parse(raw) as any;
if (props['include_in_flow'] != null) this.includeInFlow = props['include_in_flow'] as boolean;
if (props['is_reimbursable'] != null) this.isReimbursable = props['is_reimbursable'] as boolean;
if (props['service_fee'] != null) {
const fee = parseFloat(props['service_fee'].toString());
this.serviceFee = isNaN(fee) || fee <= 0 ? '' : fee.toString();
}
if (props['coupon_amount'] != null) {
const coupon = parseFloat(props['coupon_amount'].toString());
this.couponAmount = isNaN(coupon) || coupon <= 0 ? '' : coupon.toString();
}
if (props['refund_transaction_id'] != null) this.selectedRefundTransactionId = props['refund_transaction_id'].toString();
if (props['refund_transaction_name'] != null) this.selectedRefundTransactionName = props['refund_transaction_name'].toString();
} catch (_e) {}
},
buildTransactionProperties(sourceNodeId : string | null) : string {
const props = {
shopping_task_ids: this.selectedShoppingTaskIds,
storage_target_id: this.selectedStorageTargetId == '' ? null : this.selectedStorageTargetId,
storage_target_name: this.selectedStorageTargetName == '' ? null : this.selectedStorageTargetName,
source_app: this.prefillSourceApp == '' ? null : this.prefillSourceApp,
pay_method: this.prefillPayMethod == '' ? null : this.prefillPayMethod,
source_node_id: sourceNodeId,
include_in_flow: this.includeInFlow,
is_reimbursable: this.isReimbursable,
service_fee: this.moneyTextToNumber(this.serviceFee),
coupon_amount: this.moneyTextToNumber(this.couponAmount),
refund_transaction_id: this.selectedRefundTransactionId == '' ? null : this.selectedRefundTransactionId,
refund_transaction_name: this.selectedRefundTransactionName == '' ? null : this.selectedRefundTransactionName
};
return JSON.stringify(props);
},
safeJson(value : any) : string {
try {
return JSON.stringify(value);
} catch (_e) {
try {
return value == null ? 'null' : value.toString();
} catch (_e2) {
return '[unserializable]';
}
}
},
applyCategoryLabel(label : string) {
const raw = (label ?? '').toString().trim();
if (raw == '') return;
const list = this.currentCategories;
for (let i = 0; i < list.length; i++) {
if (list[i].label == raw || list[i].id == raw) {
this.category = list[i].id;
return;
}
}
},
async loadEditingTransaction() {
const bill = await FinanceBiz.getTransactionMount(this.editTransactionId);
if (bill == null) {
uni.showToast({ title: '原账单不存在', icon: 'none' });
return;
}
this.amount = bill.amount.toString();
this.activeMode = bill.type == 'income' ? 'income' : 'expense';
this.prefillAccountId = bill.account_id;
this.selectedAccountId = bill.account_id;
const categoryText = bill.category == null ? '' : bill.category!.toString();
this.editCategoryLabel = categoryText;
this.editOriginalCategory = categoryText;
this.applyCategoryLabel(categoryText);
this.note = bill.description == null ? '' : bill.description!.toString();
this.location = bill.location == null ? '' : bill.location!.toString();
this.applyTransactionProperties(bill.properties == null ? null : bill.properties!.toString());
this.prefillTransactionTime = bill.transaction_time;
const d = new Date(bill.transaction_time);
const h = d.getHours().toString().padStart(2, '0');
const m = d.getMinutes().toString().padStart(2, '0');
this.displayTime = `${d.getFullYear()}-${(d.getMonth() + 1).toString().padStart(2, '0')}-${d.getDate().toString().padStart(2, '0')}, ${h}:${m}`;
},
onAmountInput(e : InputEvent) {
let val = e.detail.value;
val = val.replace(/[^0-9.]/g, '');
const dots = val.split('.').length - 1;
if (dots > 1) {
const firstDotIndex = val.indexOf('.');
val = val.substring(0, firstDotIndex + 1) + val.substring(firstDotIndex + 1).replace(/\./g, '');
}
if (val.includes('.')) {
const parts = val.split('.');
if (parts[1].length > 2) {
val = parts[0] + '.' + parts[1].substring(0, 2);
}
}
this.amount = val;
},
async loadAccounts() {
const bookId = this.isEditMode ? null : (this.selectedBookId == '' ? null : this.selectedBookId);
this.accounts = await FinanceBiz.listAccountNodes(bookId);
if (this.accounts.length > 0) {
if (this.prefillAccountId != '' && this.accounts.find((a : AccountNode) : boolean => a.id == this.prefillAccountId) != null) {
this.selectedAccountId = this.prefillAccountId;
this.prefillAccountId = '';
} else if (this.selectedAccountId == '' || this.accounts.find((a : AccountNode) : boolean => a.id == this.selectedAccountId) == null) {
this.selectedAccountId = this.accounts[0].id;
}
if (this.accounts.length > 1) {
if (this.selectedTargetAccountId == '' || this.selectedTargetAccountId == this.selectedAccountId || this.accounts.find((a : AccountNode) : boolean => a.id == this.selectedTargetAccountId) == null) {
for (let i = 0; i < this.accounts.length; i++) {
if (this.accounts[i].id != this.selectedAccountId) {
this.selectedTargetAccountId = this.accounts[i].id;
break;
}
}
}
} else {
this.selectedTargetAccountId = '';
}
} else {
this.selectedAccountId = '';
this.selectedTargetAccountId = '';
}
this.ensureSelectedAccountAllowed();
},
async loadBooks() {
this.bookOptions = await FinanceBiz.listBooks();
if (this.bookOptions.length > 0) {
if (this.selectedBookId == '' || this.bookOptions.find((b : BookNode) : boolean => b.id == this.selectedBookId) == null) {
this.selectedBookId = this.bookOptions[0].id;
}
} else {
this.selectedBookId = '';
}
await this.loadAccounts();
if (this.activeMode == 'refund') {
await this.loadRefundCandidates();
}
if (this.isEditMode && this.editCategoryLabel.trim() != '') {
this.applyCategoryLabel(this.editCategoryLabel);
this.editCategoryLabel = '';
}
},
showAccountPicker() {
const candidates = this.accountCandidates;
if (candidates.length == 0) {
uni.showToast({ title: '请先创建账户', icon: 'none' });
return;
}
const itemList = candidates.map((a) : string => this.accountDisplayText(a));
uni.showActionSheet({
itemList: itemList,
success: (res) => {
this.selectedAccountId = candidates[res.tapIndex].id;
}
});
},
showBookPicker() {
if (this.bookOptions.length == 0) return;
const itemList = this.bookOptions.map((b) : string => b.name);
itemList.push('＋ 新建账本');
uni.showActionSheet({
itemList: itemList,
success: (res) => {
if (res.tapIndex == this.bookOptions.length) {
uni.showModal({
title: '新建账本',
editable: true,
placeholderText: '请输入账本名称',
success: (modalRes) => {
if (!modalRes.confirm) return;
const val = (modalRes.content ?? '').toString().trim();
if (val == '') {
uni.showToast({ title: '账本名称不能为空', icon: 'none' });
return;
}
FinanceBiz.createBook(val).then((id) => {
if (id == null || id == '') {
uni.showToast({ title: '创建账本失败', icon: 'none' });
return;
}
this.loadBooks().then(() => {
this.selectedBookId = id;
uni.showToast({ title: '账本已创建', icon: 'none' });
});
});
}
});
return;
}
if (res.tapIndex >= 0 && res.tapIndex < this.bookOptions.length) {
this.selectedBookId = this.bookOptions[res.tapIndex].id;
}
}
});
},
showTargetAccountPicker() {
if (this.accounts.length <= 1) {
uni.showToast({ title: '至少需要两个账户', icon: 'none' });
return;
}
const candidates = this.accounts.filter((a : AccountNode) : boolean => a.id != this.selectedAccountId);
const itemList = candidates.map((a) : string => this.accountDisplayText(a));
uni.showActionSheet({
itemList: itemList,
success: (res) => {
if (res.tapIndex >= 0 && res.tapIndex < candidates.length) {
this.selectedTargetAccountId = candidates[res.tapIndex].id;
}
}
});
},
isActiveTaskStatus(status : string) : boolean {
const raw = (status ?? '').toString().toLowerCase();
return raw != 'done' && raw != 'completed' && raw != 'archived' && raw != 'abandoned' && raw != '3';
},
isProjectTaskCandidate(task : Task) : boolean {
return this.isActiveTaskStatus(task.status) && !TaskBiz.isStorageEntityTask(task);
},
shouldAutoCompleteLinkedTask(task : Task) : boolean {
return TaskBiz.getTaskCategory(task) == '购物';
},
async refreshTaskCandidatesWithSync(source : string, showLoading : boolean = false) {
if (showLoading) {
uni.showLoading({ title: '刷新关联数据...', mask: true });
}
try {
try {
await EcosystemAppBootstrap.runForegroundSync(FINANCE_APP_PROFILE, source);
} catch (e) {
console.warn('[zemo.finance] record sync refresh failed', e);
}
await this.loadTaskCandidates();
} finally {
if (showLoading) {
uni.hideLoading();
}
}
},
async loadTaskCandidates() {
this.allTasks = await TaskBiz.getAllTasks();
this.shoppingCandidates = this.allTasks.filter((t : Task) : boolean => {
return this.isProjectTaskCandidate(t);
});
this.storageCandidates = this.allTasks.filter((t : Task) : boolean => {
return this.isActiveTaskStatus(t.status) && TaskBiz.isStorageBoxTask(t);
});
},
async showTaskPicker() {
await this.refreshTaskCandidatesWithSync('record-task-picker', true);
if (this.shoppingCandidates.length == 0) {
uni.showToast({ title: '当前没有可关联任务', icon: 'none' });
return;
}
const itemList = this.shoppingCandidates.map((t) : string => t.title);
uni.showActionSheet({
itemList: itemList,
success: (res) => {
const task = this.shoppingCandidates[res.tapIndex];
this.selectedShoppingTaskIds = [task.id];
this.selectedShoppingTaskName = task.title;
}
});
},
async showStoragePicker() {
await this.refreshTaskCandidatesWithSync('record-storage-picker', true);
if (this.storageCandidates.length == 0) {
uni.showToast({ title: '当前没有可选收纳任务', icon: 'none' });
return;
}
const itemList = this.storageCandidates.map((t) : string => t.title);
uni.showActionSheet({
itemList: itemList,
success: (res) => {
const target = this.storageCandidates[res.tapIndex];
this.selectedStorageTargetId = target.id;
this.selectedStorageTargetName = target.title;
}
});
},
buildStorageItemNote(amount : number, shoppingTitles : string[]) : string {
const lines = [] as string[];
lines.push(`来源账单: ${this.note == '' ? '手动记账' : this.note}`);
lines.push(`关联任务: ${shoppingTitles.length > 0 ? shoppingTitles.join('、') : '未关联'}`);
lines.push(`收纳位置: ${this.selectedStorageTargetName == '' ? '未选择' : this.selectedStorageTargetName}`);
lines.push(`金额: ${amount.toFixed(2)}`);
lines.push(`定位: ${this.location == '' ? '未填写' : this.location}`);
lines.push(`时间: ${Date.now()}`);
return lines.join('\n');
},
finishSubmitAndMaybeBackground() {
const shouldBackground = this.autoBackgroundAfterSubmit;
this.autoBackgroundAfterSubmit = false;
setTimeout(() => {
this.closeSheet();
if (shouldBackground) {
setTimeout(() => {
AppBackgroundService.moveToBackground();
}, 260);
}
}, 360);
},
async submit() {
const val = parseFloat(this.amount);
if (isNaN(val) || val <= 0) {
uni.showToast({ title: '请输入有效金额', icon: 'none' });
return;
}
if (this.selectedAccountId == '') {
uni.showToast({ title: '请选择账户', icon: 'none' });
return;
}

if (this.isEditMode) {
const updatePayload = {
account_id: this.selectedAccountId,
amount: val,
type: this.financeType,
category: this.effectiveCategory,
description: this.note,
location: this.location,
transaction_time: this.prefillTransactionTime > 0 ? this.prefillTransactionTime : null,
properties: this.buildTransactionProperties(null)
} as UpdateTransactionPayload;
console.log(`[FinanceRecord][Debug] record_update_payload=${this.safeJson({ id: this.editTransactionId, payload: updatePayload })}`);
const ok = await FinanceBiz.updateTransaction(this.editTransactionId, updatePayload);
console.log(`[FinanceRecord][Debug] record_update_result id=${this.editTransactionId}, ok=${ok ? 'true' : 'false'}`);
if (ok) {
uni.showToast({ title: '账单已更新', icon: 'success' });
this.finishSubmitAndMaybeBackground();
} else {
uni.showToast({ title: '保存失败', icon: 'none' });
}
return;
}

if (this.activeMode == 'refund' && this.selectedRefundTransactionId == '') {
uni.showToast({ title: '请选择退款账单', icon: 'none' });
return;
}

if (this.activeMode == 'transfer') {
if (this.selectedTargetAccountId == '' || this.selectedTargetAccountId == this.selectedAccountId) {
uni.showToast({ title: '请选择有效转入账户', icon: 'none' });
return;
}
const transferDesc = this.note == '' ? '账户转账' : this.note;
console.log(`[FinanceRecord][Debug] record_transfer_payload=${this.safeJson({
fromAccountId: this.selectedAccountId,
toAccountId: this.selectedTargetAccountId,
amount: val,
description: transferDesc,
category: this.effectiveCategory,
location: this.location,
properties: this.buildTransactionProperties(null)
})}`);
const transferOk = await FinanceBiz.transferBetweenAccounts(
this.selectedAccountId,
this.selectedTargetAccountId,
val,
transferDesc,
this.effectiveCategory,
this.location,
this.buildTransactionProperties(null)
);
console.log(`[FinanceRecord][Debug] record_transfer_result ok=${transferOk ? 'true' : 'false'}`);
if (transferOk) {
uni.showToast({ title: '转账成功', icon: 'success' });
this.finishSubmitAndMaybeBackground();
} else {
uni.showToast({ title: '转账失败', icon: 'none' });
}
return;
}

		const sourceNodeId = this.selectedShoppingTaskIds.length > 0 ? this.selectedShoppingTaskIds[0] : null;
		const createPayload = {
			account_id: this.selectedAccountId,
			amount: val,
			type: this.financeType,
			category: this.effectiveCategory,
			description: this.note,
			location: this.location,
			transaction_time: this.prefillTransactionTime > 0 ? this.prefillTransactionTime : null,
			source_node_id: sourceNodeId,
			item_node_id: sourceNodeId,
			location_node_id: this.selectedStorageTargetId == '' ? null : this.selectedStorageTargetId,
			properties: this.buildTransactionProperties(sourceNodeId),
			receipt_paths: [] as string[]
		} as CreateTransactionForNodesPayload;
		console.log(`[FinanceRecord][Debug] record_create_payload=${this.safeJson(createPayload)}`);
		const transactionId = await FinanceBiz.createTransactionForNodes(createPayload);
		console.log(`[FinanceRecord][Debug] record_create_result id=${transactionId == null ? '' : transactionId}`);

		if (transactionId == null || transactionId == '') {
uni.showToast({ title: '记账失败', icon: 'none' });
return;
}

const selectedTitles = [] as string[];
if (this.activeMode == 'expense') {
for (let i = 0; i < this.shoppingCandidates.length; i++) {
if (this.selectedShoppingTaskIds.indexOf(this.shoppingCandidates[i].id) >= 0) {
selectedTitles.push(this.shoppingCandidates[i].title);
}
}

for (let i = 0; i < this.selectedShoppingTaskIds.length; i++) {
const task = this.shoppingCandidates.find((candidate : Task) : boolean => candidate.id == this.selectedShoppingTaskIds[i]);
if (task != null && this.shouldAutoCompleteLinkedTask(task)) {
await TaskBiz.completeTask(this.selectedShoppingTaskIds[i]);
}
}

if (this.selectedStorageTargetId != '') {
if (this.categoryLabel == '快递') {
await AutoFinanceService.createPickupTaskFromBookkeeping(
this.note,
this.selectedStorageTargetId,
this.selectedStorageTargetName,
this.selectedShoppingTaskIds
);
} else {
					const storageNote = this.buildStorageItemNote(val, selectedTitles);
					let itemNames = selectedTitles;
					if (itemNames.length == 0) {
						const fallbackName = this.note.trim() == '' ? '记账入箱物品' : this.note.trim();
						itemNames = [fallbackName];
					}

					for (let i = 0; i < itemNames.length; i++) {
						await TaskBiz.createStorageItem(this.selectedStorageTargetId, {
							item_name: itemNames[i],
							note: storageNote,
							amount: val,
							attachments: [] as string[]
						} as CreateStorageItemPayload);
					}
}
}
}

uni.showToast({ title: '记账成功', icon: 'success' });
this.finishSubmitAndMaybeBackground();
},
deleteCurrentTransaction() {
if (!this.isEditMode || this.deletingTransaction) return;
uni.showModal({
title: '删除账单',
content: '删除后会同步回滚账户余额，确认删除？',
confirmText: '删除',
confirmColor: '#e85d67',
success: (res) => {
if (!res.confirm) return;
this.deletingTransaction = true;
FinanceBiz.deleteTransaction(this.editTransactionId).then((ok) => {
if (ok) {
uni.showToast({ title: '账单已删除', icon: 'success' });
uni.removeStorageSync(AppDialogApi.FINANCE_RECORD_EDIT_ID_KEY);
uni.setStorageSync('zemo_finance_home_skip_reload_until', (Date.now() + 3000).toString());
uni.setStorageSync('zemo_finance_home_deleted_transaction_id', this.editTransactionId);
this.finishSubmitAndMaybeBackground();
} else {
uni.showToast({ title: '删除失败', icon: 'none' });
this.deletingTransaction = false;
}
}).catch((_e) => {
uni.showToast({ title: '删除失败', icon: 'none' });
this.deletingTransaction = false;
});
}
});
}
}
}
</script>

<style>
