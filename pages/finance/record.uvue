border-width: 1px;
border-color: #ccd5dc;
}

.info-select-icon {
font-size: 13px;
margin-right: 5px;
}

.info-select-text {
flex: 1;
font-size: 12px;
color: #1f2a33;
font-weight: 700;
lines: 1;
text-overflow: ellipsis;
}

.info-select-arrow {
