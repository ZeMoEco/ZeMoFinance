color: #5c6570;
}

.refund-picker {
position: relative;
z-index: 9000;
overflow: visible;
margin-top: 9px;
background-color: #e7edf2;
border-radius: 13px;
padding: 8px;
border-width: 1px;
border-color: #ced8df;
}

.refund-fill-label {
font-size: 12px;
font-weight: 700;
color: #6c7782;
margin-bottom: 6px;
}

.refund-fill-row {
height: 42px;
border-radius: 18px;
background-color: #edf3f7;
border-width: 1px;
