}

.time-chip {
flex-direction: row;
align-items: center;
max-width: 108px;
padding: 5px 8px;
border-radius: 999px;
background-color: #e7edf2;
border-width: 1px;
border-color: #cfd8df;
}

.time-chip-icon {
font-size: 12px;
margin-right: 3px;
}

.time-chip-text {
font-size: 12px;
font-weight: 700;
color: #1f2a34;
}

.divider {
height: 1px;
background-color: #d8dfe5;
margin-top: 8px;
}

.info-row-grid {
margin-top: 9px;
flex-direction: row;
justify-content: space-between;
}

.info-cell {
width: 49%;
}

.info-label {
font-size: 12px;
font-weight: 700;
color: #6c7782;
margin-bottom: 6px;
}

.info-select-pill {
height: 38px;
border-radius: 19px;
background-color: #e4eaef;
padding: 0 10px;
flex-direction: row;
