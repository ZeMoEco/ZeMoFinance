  private static buildHarmonyPhysicalPackageFolder(folderName: string): string {

    // #ifdef APP-HARMONY
    const dir = ExportImportService.buildHarmonyPhysicalWorkDir('full_export')
    if (dir != '') {
      const folderPath = `${dir}/${folderName}`
      ExportImportService.ensureHarmonyPhysicalDir(folderPath)
      return folderPath
    }
    // #endif

    return joinPath(RUNTIME_FULL_EXPORT_DIR, folderName)

  }

  private static buildHarmonyPhysicalWorkDir(childDir: string): string {

    // #ifdef APP-HARMONY
    let baseDir = ''
    try {
      const ctx = getContext() as common.UIAbilityContext
      baseDir = ((ctx.filesDir ?? '') as string).toString().replace(/\\/g, '/').replace(/\/+$/, '')
    } catch (_e0) {}

    if (baseDir == '') {
      try {
        const dbPath = (DB.getDatabasePath() ?? '').toString().replace(/\\/g, '/')
        const slash = dbPath.lastIndexOf('/')
        if (slash > 0) baseDir = dbPath.substring(0, slash)
      } catch (_e1) {}
    }

    if (baseDir == '') return ''

    const rootDir = `${baseDir}/zemo_sync_work`
    if (!ExportImportService.ensureHarmonyPhysicalDir(rootDir)) return ''

    const safeChildDir = (childDir ?? '').toString().replace(/\\/g, '/').replace(/^\/+/, '').replace(/\/+$/, '')
    if (safeChildDir == '') return rootDir

    const fullDir = `${rootDir}/${safeChildDir}`
    if (!ExportImportService.ensureHarmonyPhysicalDir(fullDir)) return ''
    return fullDir
    // #endif

    return ''

  }

  private static ensureHarmonyPhysicalDir(dirPath: string): boolean {

    // #ifdef APP-HARMONY
    const normalized = (dirPath ?? '').toString().trim().replace(/\\/g, '/')
    if (normalized == '') return false
    try {
      fs.mkdirSync(normalized, true)
      return true
    } catch (_e0) {
      try {
        return fs.accessSync(normalized)
      } catch (_e1) {
        return false
      }
    }
    // #endif

    return false

  }

  private static async cleanupExportWorkPath(path: string): Promise<void> {

    const normalized = (path ?? '').toString().trim()
    if (normalized == '') return

    // #ifdef APP-HARMONY
    if (normalized.indexOf('://') < 0) {
      try {
        const stat = fs.statSync(normalized)
        if (stat.isDirectory != null && stat.isDirectory()) {
          fs.rmdirSync(normalized, true)
          return
        }
      } catch (_e0) {}

      try {
        if (fs.accessSync(normalized)) fs.unlinkSync(normalized)
      } catch (_e1) {}
      return
    }
    // #endif

    await FileUtil.removeFile(normalized)
    await FileUtil.removeDir(normalized)

  }

  static async cleanupPackageArtifact(path: string): Promise<void> {
    await ExportImportService.cleanupExportWorkPath(path)
  }

  private static buildHarmonyExportSeedPath(srcPath: string): string {

    // #ifdef APP-HARMONY
    const normalized = (srcPath ?? '').toString().replace(/\\/g, '/')
    const slash = normalized.lastIndexOf('/')
    if (slash > 0) return `${normalized.substring(0, slash)}/zemo_pkg_seed_${Date.now()}.db`
    // #endif

    return ''

  }

  private static getReservedHarmonyExportSeedPath(): string {

    // #ifdef APP-HARMONY
    const seedPath = (ExportImportService._lastHarmonyExportSeedPath ?? '').toString().trim()
    if (seedPath == '') return ''
    try {
      if (fs.accessSync(seedPath)) return seedPath
    } catch (_e0) {}
    ExportImportService._lastHarmonyExportSeedPath = ''
    // #endif

    return ''

  }

  private static clearHarmonyExportSeedPath(): void {

    // #ifdef APP-HARMONY
    const seedPath = (ExportImportService._lastHarmonyExportSeedPath ?? '').toString().trim()
    ExportImportService._lastHarmonyExportSeedPath = ''
    if (seedPath == '') return
    try {
      if (fs.accessSync(seedPath)) fs.unlinkSync(seedPath)
    } catch (_e0) {}
    // #endif

  }

  private static getHarmonyAttachSeedDbPath(): string {

    // #ifdef APP-HARMONY
    try {
      const runtimeDbPath = (DB.getDatabasePath() ?? '').toString().replace(/\\/g, '/')
      if (runtimeDbPath != '') return runtimeDbPath
    } catch (_e0) {}

    try {
      const ctx = getContext() as common.UIAbilityContext
      const databaseDir = (ctx.databaseDir ?? '').toString().replace(/\\/g, '/').replace(/\/+$/, '')
      if (databaseDir != '') return `${databaseDir}/rdb/${getCurrentDbName()}`
    } catch (_e1) {}
    // #endif

    return ''

  }

  private static async persistAttachDbPath(attachDbPath: string, exportedDbPath: string): Promise<boolean> {

    if (attachDbPath == exportedDbPath) return true

    // #ifdef APP-HARMONY
    try { await FileUtil.removeFile(exportedDbPath) } catch (_e0) {}

    try {
      fs.copyFileSync(attachDbPath, exportedDbPath)
      if (await FileUtil.exists(exportedDbPath)) return true
    } catch (_e1) {}

    try {
      await FileUtil.copyFile(attachDbPath, exportedDbPath, { overwrite: true })
      if (await FileUtil.exists(exportedDbPath)) return true
    } catch (_e2) {}

    const attachBytes = ExportImportService.readHarmonyBinaryFile(attachDbPath)
    if (attachBytes != null) {
      const writeOk = await FileUtil.writeBinaryFile(exportedDbPath, attachBytes)
      if (writeOk && await FileUtil.exists(exportedDbPath)) return true
    }

    let destExists = false
    try {
      destExists = await FileUtil.exists(exportedDbPath)
    } catch (_e3) {}
    __f__('error','at services/export/export-import.uts:1089',`[ExportImportService] persistAttachDbPath failed src=${attachDbPath} dest=${exportedDbPath} destExists=${destExists}`)
    return false
    // #endif

    return true

  }

  private static cleanupAttachDbPath(attachDbPath: string, exportedDbPath: string): void {

    if (attachDbPath == '' || attachDbPath == exportedDbPath) return

    // #ifdef APP-HARMONY
    ExportImportService.cleanupHarmonyDbArtifacts(attachDbPath)
    if (ExportImportService._lastHarmonyExportSeedPath == attachDbPath) {
      ExportImportService._lastHarmonyExportSeedPath = ''
    }
    // #endif

  }

  private static resolveAttachDbPath(path: string): string {

    const rawPath = (path ?? '').toString().trim()

    if (rawPath == '') return rawPath

    // #ifdef APP-HARMONY
    if (rawPath.indexOf('unifile://usr/') == 0) {
      try {
        const ctx = getContext() as common.UIAbilityContext
        const baseDir = (ctx.filesDir ?? '').toString().replace(/\\/g, '/').replace(/\/+$/, '')
        const relativePath = rawPath.substring('unifile://usr/'.length).replace(/^\/+/, '')
        if (baseDir != '' && relativePath != '') {
          const resolvedPath = `${baseDir}/${relativePath}`
          try {
            if (fs.accessSync(resolvedPath)) return resolvedPath
          } catch (_e0) {}
        }
      } catch (_e1) {}
    }
    // #endif

    return rawPath

  }

  private static cleanupHarmonyDbArtifacts(dbPath: string): void {

    // #ifdef APP-HARMONY
    const normalized = (dbPath ?? '').toString().trim()
    if (normalized == '') return
    const artifacts = [normalized, `${normalized}-wal`, `${normalized}-shm`]
    for (let i = 0; i < artifacts.length; i++) {
      try {
        if (fs.accessSync(artifacts[i])) fs.unlinkSync(artifacts[i])
      } catch (_e0) {}
    }
    // #endif

  }

  private static readHarmonyBinaryFile(filePath: string): ArrayBuffer | null {

    // #ifdef APP-HARMONY
    let file: any | null = null
    try {
      if (!fs.accessSync(filePath)) return null
      file = fs.openSync(filePath, fs.OpenMode.READ_ONLY)
      const stat = fs.statSync(file.fd)
      const size = parseInt(stat.size.toString())
      const out = new ArrayBuffer(size)
      if (size > 0) fs.readSync(file.fd, out)
      return out
    } catch (_e0) {
      return null
    } finally {
      try {
        if (file != null) fs.closeSync(file)
      } catch (_e1) {}
    }
    // #endif

    return null

  }

  private static copyHarmonyBinaryFile(srcPath: string, destPath: string): boolean {

    // #ifdef APP-HARMONY
    try {
      if (srcPath == '' || destPath == '') return false
      if (!fs.accessSync(srcPath)) return false
      try {
        if (fs.accessSync(destPath)) fs.unlinkSync(destPath)
      } catch (_e0) {}
      fs.copyFileSync(srcPath, destPath)
      return fs.accessSync(destPath)
    } catch (_e1) {
      return false
    }
    // #endif

    return false

  }

  private static writeHarmonyBinaryFile(filePath: string, data: ArrayBuffer): boolean {

    // #ifdef APP-HARMONY
    let file: any | null = null
    try {
      file = fs.openSync(filePath, fs.OpenMode.CREATE | fs.OpenMode.WRITE_ONLY | fs.OpenMode.TRUNC)
      fs.writeSync(file.fd, data)
      return true
    } catch (_e0) {
      return false
    } finally {
      try {
        if (file != null) fs.closeSync(file)
      } catch (_e1) {}
    }
    // #endif

    return false

  }




  private static async mergeDatabase(importDbPath: string, context: any | null = null): Promise<boolean> {

    // const db = DB


    // #ifdef APP-HARMONY
    return await ExportImportService.mergeHarmonyDatabase(importDbPath, context)
    // #endif


    // Android：ATTACH + INSERT OR IGNORE



    try {

      let absPath = importDbPath

      // #ifdef APP-ANDROID
      try {

          // Convert unifile:// to absolute path for SQLite ATTACH

          if (absPath.startsWith('unifile://')) {

              absPath = io.dcloud.uts.UTSAndroid.convert2AbsFullPath(absPath)

          }

      } catch(_e) {}
      // #endif

      

      const attachSql = `ATTACH DATABASE '${absPath.replace(/'/g, "''")}' AS zemo_import`

      const detachSql = `DETACH DATABASE zemo_import`



      await DB.beginTransaction()

      const attached = await DB.exec(attachSql)

      if (!attached) throw new Error('ATTACH failed')



      const tables = await ExportImportService.listUserTables()

      for (const t of tables) {

        // 跳过 sqlite 系统�?

        if (t.startsWith('sqlite_')) continue



        // user_kv: merge by updated_at (do not use INSERT OR IGNORE)

        if (t == 'user_kv') {

          await ExportImportService.mergeUserKvFromAttached()

          continue

        }

        // 仅合�?import 库里存在的表

          const existsArgs: SqlArgs = [t]

        const existsInImport = await DB.query(`SELECT name FROM zemo_import.sqlite_master WHERE type='table' AND name=?`, existsArgs)

        if (existsInImport.length === 0) continue



        // 列名对齐 + 主键 + updated_at

        const cols = await DB.query(`PRAGMA table_info(${t})`)
        const importCols = await DB.query(`PRAGMA zemo_import.table_info(${t})`)
        const importColSet = new Set<string>()
        for (let i = 0; i < importCols.length; i++) {
          const importNameVal = importCols[i].get('name')
          const importName = importNameVal == null ? '' : importNameVal.toString()
          if (importName != '') importColSet.add(importName)
        }

        const colNames: string[] = []
        const mergedColNames: string[] = []

        const pkCols: string[] = []

        let hasUpdatedAt = false

        for (let i = 0; i < cols.length; i++) {

          const nameVal = cols[i].get('name')

          const nameStr = nameVal != null ? nameVal.toString() : ''

          if (nameStr.length > 0) {

            colNames.push(nameStr)
            if (importColSet.has(nameStr)) mergedColNames.push(nameStr)

            if (nameStr == 'updated_at') hasUpdatedAt = true

          }

          const pkVal = cols[i].get('pk')

          const pkN = pkVal == null ? 0 : parseInt(pkVal.toString())

          if (!isNaN(pkN) && pkN > 0 && nameStr.length > 0) pkCols.push(nameStr)

        }

        if (colNames.length === 0) continue
        if (mergedColNames.length === 0) continue

        const colList = mergedColNames.join(',')



        // Always insert missing rows

        await DB.exec(`INSERT OR IGNORE INTO ${t} (${colList}) SELECT ${colList} FROM zemo_import.${t}`)



        // Incremental update: if table has updated_at + primary key(s), update rows when incoming newer.

        if (hasUpdatedAt && importColSet.has('updated_at') && pkCols.length > 0) {

          let allPkInImport = true
          for (let i = 0; i < pkCols.length; i++) {
            if (!importColSet.has(pkCols[i])) {
              allPkInImport = false
              break
            }
          }
          if (!allPkInImport) continue

          // Build join condition: t.pk = s.pk AND ...

          const condParts: string[] = []

          for (let i = 0; i < pkCols.length; i++) {

            const k = pkCols[i]

            condParts.push(`t.${k} = s.${k}`)

          }

          const cond = condParts.join(' AND ')



          // Build SET clause for all columns (including updated_at)

          const setParts: string[] = []

          for (let i = 0; i < mergedColNames.length; i++) {

            const c = mergedColNames[i]
            if (pkCols.indexOf(c) >= 0) continue

            setParts.push(`${c} = (SELECT s.${c} FROM zemo_import.${t} s WHERE ${cond} LIMIT 1)`)

          }
          if (setParts.length == 0) continue

          const setClause = setParts.join(', ')



          // Only update when incoming updated_at is newer

          const updateSql = `UPDATE ${t} AS t SET ${setClause} WHERE EXISTS (SELECT 1 FROM zemo_import.${t} s WHERE ${cond} AND CAST(COALESCE(s.updated_at, 0) AS INTEGER) > CAST(COALESCE(t.updated_at, 0) AS INTEGER))`

          await DB.exec(updateSql)

        }

      }



      // [修复] 处理任务详情图片路径（绝对路径替换）

      try {

        const rows = await DB.query("SELECT id, json_extract(properties, '\$.media_paths') as media_paths FROM nodes WHERE type = 'log' AND json_extract(properties, '\$.media_paths') LIKE '%/assets/images/%'");

        for (let i = 0; i < rows.length; i++) {

          const row = rows[i];

          const id = row.get("id");

          const oldPathsJson = row.get("media_paths") as string | null;

          if (id != null && oldPathsJson != null && oldPathsJson.includes('/assets/images/')) {

            const reg = new RegExp('"([^"]*?)/assets/images/', 'g');

            const newPathsJson = oldPathsJson.replace(reg, '"' + RUNTIME_IMAGES_DIR + '/');

            if (newPathsJson != oldPathsJson) {
                await DB.exec("UPDATE nodes SET properties = json_set(properties, '\$.media_paths', json(?)) WHERE id = ? AND type = 'log'", [newPathsJson, id]);
            }
          }
        }
      } catch (_ep) {}



      await DB.exec(detachSql)

      await DB.setTransactionSuccessful()

      // [Fix]: Sync DB user_kv back to Storage after import ends

      try {

        const keys = [

          'vision_saved_groups',

          'vision_saved_connections',

          'vision_group_view_states',

          'vision_deleted_auto_groups',

          'vision_limit_view_state'

        ];

        const placeholders = keys.map(_ => '?').join(',');

        const rows = await DB.query(`SELECT k, v FROM user_kv WHERE k IN (${placeholders})`, keys as any[] as SqlValue[]);

        for (let i=0; i<rows.length; i++) {

           const row = rows[i];

           const k = row.get('k');

           const v = row.get('v');

           if (k != null && v != null) {

               uni.setStorageSync(k.toString(), v.toString());

           }

        }

      } catch (_e1) {

        __f__('error','at services/export/export-import.uts:518','Storage sync from DB after import failed', _e1);

      }

      // [Fix]: Sync DB user_kv back to Storage after import ends

      try {

        const keys = [

          'vision_saved_groups',

          'vision_saved_connections',

          'vision_group_view_states',

          'vision_deleted_auto_groups',

          'vision_limit_view_state'

        ];

        const placeholders = keys.map(_ => '?').join(',');

        const rows = await DB.query(`SELECT k, v FROM user_kv WHERE k IN (${placeholders})`, keys as any[] as SqlValue[]);

        for (let i=0; i<rows.length; i++) {

           const row = rows[i];

           const k = row.get('k');

           const v = row.get('v');

           if (k != null && v != null) {

               uni.setStorageSync(k.toString(), v.toString());

           }

        }

      } catch (_e1) {

        __f__('error','at services/export/export-import.uts:540','Storage sync from DB after import failed', _e1);

      }

      return true

    } catch (e) {

      __f__('error','at services/export/export-import.uts:544',`[ExportImportService] mergeDatabase android error: ${e}`)

      return false

    } finally {

      await DB.endTransaction()

    }





    // Harmony：拷贝到 rdb 目录 + 打开临时 store，再逐表 INSERT OR IGNORE�?
























































































































































































































































































































































































  }

  private static async mergeHarmonyDatabase(importDbPath: string, _context: any | null = null): Promise<boolean> {

    let tempImportDbPath = ''
    let importStore: relationalStore.RdbStore | null = null
    let committed = false

    try {

      tempImportDbPath = await ExportImportService.prepareHarmonyImportDbPath(importDbPath)
      if (tempImportDbPath == '') throw new Error('prepare harmony import db failed')

      importStore = await ExportImportService.openHarmonyTempStore(tempImportDbPath)
      if (importStore == null) throw new Error('open harmony import db failed')

      await DB.beginTransaction()

      const tables = await ExportImportService.listUserTables()

      for (let i = 0; i < tables.length; i++) {

        const table = tables[i]
        if (table.startsWith('sqlite_')) continue

        const existsInImport = await ExportImportService.queryHarmonyStore(importStore, `SELECT name FROM sqlite_master WHERE type='table' AND name=?`, [table])
        if (existsInImport.length == 0) continue

        if (table == 'user_kv') {
          await ExportImportService.mergeUserKvFromHarmony(importStore)
          continue
        }

        const liveMeta = await ExportImportService.describeLiveTable(table)
        if (liveMeta.colNames.length == 0) continue

        const importColumns = await ExportImportService.getHarmonyStoreTableColumns(importStore, table)
        const mergedColumns = [] as string[]
        for (let c = 0; c < liveMeta.colNames.length; c++) {
          const column = liveMeta.colNames[c]
          if (importColumns.has(column)) mergedColumns.push(column)
        }
        if (mergedColumns.length == 0) continue

        const sourceRows = await ExportImportService.queryHarmonyStore(importStore, `SELECT ${mergedColumns.join(',')} FROM ${table}`)
        const placeholders = mergedColumns.map(_ => '?').join(', ')

        for (let r = 0; r < sourceRows.length; r++) {

          const sourceRow = sourceRows[r]
          const insertArgs = [] as SqlArgs
          for (let c = 0; c < mergedColumns.length; c++) {
            insertArgs.push(sourceRow.get(mergedColumns[c]) as SqlValue)
          }

          if (liveMeta.pkCols.length == 0) {
            const insertOk = await DB.exec(`INSERT OR IGNORE INTO ${table} (${mergedColumns.join(',')}) VALUES (${placeholders})`, insertArgs)
            if (!insertOk) throw new Error(`insert import row failed: ${table}`)
            continue
          }

          const whereParts = [] as string[]
          const whereArgs = [] as SqlArgs
          let missingPk = false

          for (let p = 0; p < liveMeta.pkCols.length; p++) {
            const pk = liveMeta.pkCols[p]
            if (!importColumns.has(pk)) {
              missingPk = true
              break
            }
            whereParts.push(`${pk} = ?`)
            whereArgs.push(sourceRow.get(pk) as SqlValue)
          }

          if (missingPk || whereParts.length == 0) continue

          const localRows = await DB.query(`SELECT updated_at FROM ${table} WHERE ${whereParts.join(' AND ')} LIMIT 1`, whereArgs)
          if (localRows.length == 0) {
            const insertOk = await DB.exec(`INSERT OR IGNORE INTO ${table} (${mergedColumns.join(',')}) VALUES (${placeholders})`, insertArgs)
            if (!insertOk) throw new Error(`insert missing row failed: ${table}`)
            continue
          }

          if (!liveMeta.hasUpdatedAt || mergedColumns.indexOf('updated_at') < 0) continue

          const sourceUpdatedAtRaw = sourceRow.get('updated_at')
          const localUpdatedAtRaw = localRows[0].get('updated_at')
          const sourceUpdatedAt = sourceUpdatedAtRaw == null ? 0 : parseInt(sourceUpdatedAtRaw.toString())
          const localUpdatedAt = localUpdatedAtRaw == null ? 0 : parseInt(localUpdatedAtRaw.toString())

          if (sourceUpdatedAt <= localUpdatedAt) continue

          const setColumns = [] as string[]
          const updateArgs = [] as SqlArgs
          for (let c = 0; c < mergedColumns.length; c++) {
            const column = mergedColumns[c]
            if (liveMeta.pkCols.indexOf(column) >= 0) continue
            setColumns.push(`${column} = ?`)
            updateArgs.push(sourceRow.get(column) as SqlValue)
          }
          if (setColumns.length == 0) continue

          for (let a = 0; a < whereArgs.length; a++) updateArgs.push(whereArgs[a])
          const updateOk = await DB.exec(`UPDATE ${table} SET ${setColumns.join(', ')} WHERE ${whereParts.join(' AND ')}`, updateArgs)
          if (!updateOk) throw new Error(`update newer row failed: ${table}`)

        }

      }

      try {

        const rows = await DB.query("SELECT id, json_extract(properties, '$.media_paths') as media_paths FROM nodes WHERE type = 'log' AND json_extract(properties, '$.media_paths') LIKE '%/assets/images/%'")

        for (let i = 0; i < rows.length; i++) {

          const row = rows[i]
          const id = row.get('id')
          const oldPathsJson = row.get('media_paths') as string | null

          if (id != null && oldPathsJson != null && oldPathsJson.includes('/assets/images/')) {

            const reg = new RegExp('"([^"]*?)/assets/images/', 'g')
            const newPathsJson = oldPathsJson.replace(reg, '"' + RUNTIME_IMAGES_DIR + '/')

            if (newPathsJson != oldPathsJson) {
              await DB.exec("UPDATE nodes SET properties = json_set(properties, '$.media_paths', json(?)) WHERE id = ? AND type = 'log'", [newPathsJson, id as SqlValue])
            }
          }
        }
      } catch (_ep) {}

      await DB.setTransactionSuccessful()
      committed = true
      await ExportImportService.syncStorageFromDbAfterImport('at services/export/export-import.uts:540')

      return true

    } catch (e) {

      __f__('error','at services/export/export-import.uts:544',`[ExportImportService] mergeHarmonyDatabase error: ${e}`)

      return false

    } finally {

      try {
        const closable = importStore as any
        if (closable != null && closable.close != null) closable.close()
      } catch (_e0) {}

      await DB.endTransaction()

      if (tempImportDbPath != '') {
        ExportImportService.cleanupHarmonyDbArtifacts(tempImportDbPath)
      }

    }

  }

  private static async prepareHarmonyImportDbPath(importDbPath: string): Promise<string> {

    const sourcePath = (importDbPath ?? '').toString().trim()
    if (sourcePath == '') return ''

    const liveDbPath = ExportImportService.getHarmonyAttachSeedDbPath()
    const slash = liveDbPath.lastIndexOf('/')
    if (slash <= 0) return ''

    const tempImportDbPath = `${liveDbPath.substring(0, slash)}/zemo_import_${Date.now()}.db`
    ExportImportService.cleanupHarmonyDbArtifacts(tempImportDbPath)

    if (sourcePath.indexOf('://') < 0 && ExportImportService.copyHarmonyBinaryFile(sourcePath, tempImportDbPath)) {
      return tempImportDbPath
    }

    const importBytes = await FileUtil.readBinaryFile(sourcePath)
    if (importBytes == null) return ''
    if (!ExportImportService.writeHarmonyBinaryFile(tempImportDbPath, importBytes)) return ''
    return tempImportDbPath

  }

  private static async describeLiveTable(table: string): Promise<{ colNames: string[], pkCols: string[], hasUpdatedAt: boolean }> {

    const cols = await DB.query(`PRAGMA table_info(${table})`)
    const colNames = [] as string[]
    const pkCols = [] as string[]
    let hasUpdatedAt = false

    for (let i = 0; i < cols.length; i++) {

      const nameVal = cols[i].get('name')
      const nameStr = nameVal != null ? nameVal.toString() : ''
      if (nameStr == '') continue

      colNames.push(nameStr)
      if (nameStr == 'updated_at') hasUpdatedAt = true

      const pkVal = cols[i].get('pk')
      const pkN = pkVal == null ? 0 : parseInt(pkVal.toString())
      if (!isNaN(pkN) && pkN > 0) pkCols.push(nameStr)

    }

    return { colNames, pkCols, hasUpdatedAt }

  }

  private static async syncStorageFromDbAfterImport(logTag: string): Promise<void> {

    try {

      const keys = [

        'vision_saved_groups',

        'vision_saved_connections',

        'vision_group_view_states',

        'vision_deleted_auto_groups',

        'vision_limit_view_state'

      ]

      const placeholders = keys.map(_ => '?').join(',')

      const rows = await DB.query(`SELECT k, v FROM user_kv WHERE k IN (${placeholders})`, keys as any[] as SqlValue[])

      for (let i = 0; i < rows.length; i++) {

        const row = rows[i]
        const k = row.get('k')
        const v = row.get('v')

        if (k != null && v != null) {
          uni.setStorageSync(k.toString(), v.toString())
        }

      }

    } catch (_e1) {

      __f__('error',logTag,'Storage sync from DB after import failed', _e1)

    }

  }



  private static async mergeUserKvFromAttached(): Promise<void> {

    try {

      const rows = await DB.query('SELECT user_id, k, v, updated_at FROM zemo_import.user_kv')

      for (let i = 0; i < rows.length; i++) {

        const userIdRaw = rows[i].get('user_id')

        const kRaw = rows[i].get('k')

        const vRaw = rows[i].get('v')

        const tsRaw = rows[i].get('updated_at')



        const userId = userIdRaw == null ? 0 : parseInt(userIdRaw.toString())

        const k = kRaw == null ? '' : kRaw.toString()

        if (k.length == 0) continue

        const incomingTs = tsRaw == null ? 0 : parseInt(tsRaw.toString())

        const v = vRaw == null ? null : vRaw.toString()



        const localRows = await DB.query('SELECT updated_at FROM user_kv WHERE user_id = ? AND k = ? LIMIT 1', [userId, k])

        let localTs = 0

        if (localRows.length > 0) {

          const localTsRaw = localRows[0].get('updated_at')

          localTs = localTsRaw == null ? 0 : parseInt(localTsRaw.toString())

        }



        if (incomingTs > localTs) {

          const args: SqlArgs = [userId, k, v, incomingTs]

          await DB.exec('INSERT OR REPLACE INTO user_kv (user_id, k, v, updated_at) VALUES (?, ?, ?, ?)', args)

        }

      }

    } catch (e) {

      __f__('error','at services/export/export-import.uts:794',`[ExportImportService] mergeUserKvFromAttached error: ${e}`)

    }

  }























































































  private static async mergeUserKvFromHarmony(importStore: relationalStore.RdbStore): Promise<void> {

    try {

      const rows = await ExportImportService.queryHarmonyStore(importStore, 'SELECT user_id, k, v, updated_at FROM user_kv')

      for (let i = 0; i < rows.length; i++) {

        const userIdRaw = rows[i].get('user_id')
        const kRaw = rows[i].get('k')
        const vRaw = rows[i].get('v')
        const tsRaw = rows[i].get('updated_at')

        const userId = userIdRaw == null ? 0 : parseInt(userIdRaw.toString())
        const k = kRaw == null ? '' : kRaw.toString()
        if (k.length == 0) continue

        const incomingTs = tsRaw == null ? 0 : parseInt(tsRaw.toString())
        const v = vRaw == null ? null : vRaw.toString()

        const localRows = await DB.query('SELECT updated_at FROM user_kv WHERE user_id = ? AND k = ? LIMIT 1', [userId, k])
        let localTs = 0

        if (localRows.length > 0) {
          const localTsRaw = localRows[0].get('updated_at')
          localTs = localTsRaw == null ? 0 : parseInt(localTsRaw.toString())
        }

        if (incomingTs > localTs) {
          const args: SqlArgs = [userId, k, v, incomingTs]
          await DB.exec('INSERT OR REPLACE INTO user_kv (user_id, k, v, updated_at) VALUES (?, ?, ?, ?)', args)
        }

      }

    } catch (e) {

      __f__('error','at services/export/export-import.uts:794',`[ExportImportService] mergeUserKvFromHarmony error: ${e}`)

    }

  }





  private static async listUserTables(): Promise<string[]> {

    const rows = await DB.query("SELECT name FROM sqlite_master WHERE type='table'")

    const out: string[] = []

    for (let i = 0; i < rows.length; i++) {

      const nameVal = rows[i].get('name')

      const nameStr = nameVal != null ? nameVal.toString() : ''

      if (nameStr.length > 0) out.push(nameStr)

    }

    return out

  }

}
