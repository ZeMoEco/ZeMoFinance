function __f__(level: string, tag: string, message: any, detail: any | null = null): void {
  try {
    const g: any = globalThis as any
    const nativeTrace = g != null ? g.__f__ : null
    if (nativeTrace != null && nativeTrace !== __f__) {
      nativeTrace(level, tag, message, detail)
      return
    }
  } catch (_e0) {}

  if (level == 'error') {
    if (detail != null) {
      console.error(tag, message, detail)
    } else {
      console.error(tag, message)
    }
    return
  }

  if (detail != null) {
    console.log(tag, message, detail)
  } else {
    console.log(tag, message)
  }
}















export type ExportResult = {

  ok: boolean

  mode: 'db_only' | 'full'

  path?: string

  message?: string

  artifactFormat?: string

}

export type ExportPackageWindowMode = 'all' | 'before_cutoff' | 'since_cutoff'

export type ExportPackageOptions = {

  packagePrefix: string

  windowMode: ExportPackageWindowMode

  cutoffMs?: number | null

}



export class ExportImportService {

  private static _lastHarmonyExportSeedPath: string = ''

  /**

   * 纯数据库导出：复�?ZeMo.db 到沙箱可写目录�?

   * 返回导出文件路径�?

   */

  static async exportDbOnly(createHarmonySeed: boolean = false, preferPhysicalOutput: boolean = false): Promise<ExportResult> {

    try {

      await FileUtil.ensureRuntimeDirs()



      // 复用现有 BackupService 的“关闭DB+复制DB”能力：

      // �?BackupService 会导出到 Downloads/filesDir，不符合我们目录规范�?

      // 这里直接走最稳妥的“取 DB 物理路径 + copy”�?



      // [Fix]: Sync Storage to DB user_kv before export

      try {

        const keys = [

          'vision_saved_groups',

          'vision_saved_connections',

          'vision_group_view_states',

          'vision_deleted_auto_groups',

          'vision_limit_view_state'

        ];

        for(let i=0; i<keys.length; i++) {

            const val = uni.getStorageSync(keys[i]);

            if (val != null && (val as string) !== '') {

                await DB.exec('INSERT OR REPLACE INTO user_kv (user_id, k, v, updated_at) VALUES (?, ?, ?, ?)', [0, keys[i], val as string, Date.now()]);

            }

        }

      } catch (_e0) {

        __f__('error','at services/export/export-import.uts:71','Storage sync prior to DB export failed', _e0);

      }



      // [Fix]: Sync Storage to DB user_kv before export

      try {

        const keys = [

          'vision_saved_groups',

          'vision_saved_connections',

          'vision_group_view_states',

          'vision_deleted_auto_groups',

          'vision_limit_view_state'

        ];

        for(let i=0; i<keys.length; i++) {

            const val = uni.getStorageSync(keys[i]);

            if (val != null && (val as string) !== '') {

                await DB.exec('INSERT OR REPLACE INTO user_kv (user_id, k, v, updated_at) VALUES (?, ?, ?, ?)', [0, keys[i], val as string, Date.now()]);

            }

        }

      } catch (_e0) {

        __f__('error','at services/export/export-import.uts:90','Storage sync prior to DB export failed', _e0);

      }


      const time = formatDateForFile(new Date())

      let destPath = joinPath(RUNTIME_DB_EXPORT_DIR, `${EXPORT_DB_PREFIX}${time}.db`)

      // #ifdef APP-HARMONY
      if (preferPhysicalOutput) {
        destPath = ExportImportService.buildHarmonyPhysicalDbExportPath(`${EXPORT_DB_PREFIX}${time}.db`)
      }
      // #endif



      const srcPath = await ExportImportService.getCurrentDbFilePath()

      if (srcPath == null || srcPath.length == 0) {

        await DBInit.run(null)

        return { ok: false, mode: 'db_only', message: '无法获取数据库文件路径 ' }

      }


      DB.close()

      ExportImportService.clearHarmonyExportSeedPath()

      // #ifdef APP-HARMONY
      if (preferPhysicalOutput) {
        const copied = ExportImportService.copyHarmonyBinaryFile(srcPath, destPath)
        await DBInit.run(null)
        if (!copied) {
          return { ok: false, mode: 'db_only', message: '导出物理数据库快照失败' }
        }
        return { ok: true, mode: 'db_only', path: destPath }
      }

      if (createHarmonySeed) {
        const seedPath = ExportImportService.buildHarmonyExportSeedPath(srcPath)
        if (seedPath != '' && ExportImportService.copyHarmonyBinaryFile(srcPath, seedPath)) {
          ExportImportService._lastHarmonyExportSeedPath = seedPath
        } else {
          __f__('log','at services/export/export-import.uts:109',`[ExportImportService] exportDbOnly seed copy failed src=${srcPath} seed=${seedPath}`)
        }
      }
      // #endif



      await FileUtil.copyFile(srcPath, destPath, { overwrite: true })

      await DBInit.run(null)



      return { ok: true, mode: 'db_only', path: destPath }

    } catch (e) {

      __f__('error','at services/export/export-import.uts:109',`[ExportImportService] exportDbOnly error: ${e}`)

      return { ok: false, mode: 'db_only', message: (e as Error).message }

    }

  }

  static async exportPackageZip(options: ExportPackageOptions): Promise<ExportResult> {

    let packageFolder = ''

    let filteredDbPath = ''

    let zipPath = ''

    let returnedPath = ''

    try {

      await FileUtil.ensureRuntimeDirs()

      const windowMode = options.windowMode ?? 'all'

      const cutoffMs = options.cutoffMs == null ? 0 : parseInt(options.cutoffMs.toString())

      const safePrefixRaw = (options.packagePrefix ?? 'sync_package').toString().trim()

      const safePrefix = safePrefixRaw == '' ? 'sync_package' : safePrefixRaw.replace(/[^a-zA-Z0-9_-]/g, '_')

  const useHarmonyPhysicalWorkDir = ExportImportService.shouldUseHarmonyPhysicalPackageWorkDir()

  const dbRes = await ExportImportService.exportDbWindow(windowMode, cutoffMs, useHarmonyPhysicalWorkDir)

      if (!dbRes.ok || dbRes.path == null || dbRes.path.toString().trim() == '') {

        return { ok: false, mode: 'full', message: dbRes.message ?? '导出包数据库失败' }

      }

      filteredDbPath = dbRes.path.toString()

      if (useHarmonyPhysicalWorkDir) {
        returnedPath = filteredDbPath
        return { ok: true, mode: 'full', path: filteredDbPath, artifactFormat: 'db', message: 'Harmony raw db package' }
      }

      const time = formatDateForFile(new Date())

      packageFolder = useHarmonyPhysicalWorkDir
        ? ExportImportService.buildHarmonyPhysicalPackageFolder(`${safePrefix}_${time}`)
        : joinPath(RUNTIME_FULL_EXPORT_DIR, `${safePrefix}_${time}`)

      if (!useHarmonyPhysicalWorkDir) {
        await FileUtil.ensureDir(packageFolder)
      }

      await FileUtil.copyFile(filteredDbPath, joinPath(packageFolder, getCurrentDbName()), { overwrite: true })

      await FileUtil.copyDir(RUNTIME_IMAGES_DIR, joinPath(packageFolder, FULL_EXPORT_IMAGES_SUBDIR), { overwrite: true })

      await FileUtil.copyDir(RUNTIME_MUSIC_DIR, joinPath(packageFolder, FULL_EXPORT_MUSIC_SUBDIR), { overwrite: true })

      await FileUtil.copyDir(RUNTIME_VIDEOS_DIR, joinPath(packageFolder, FULL_EXPORT_VIDEOS_SUBDIR), { overwrite: true })

      await FileUtil.copyDir(RUNTIME_NOTE_DOCS_DIR, joinPath(packageFolder, FULL_EXPORT_NOTE_DOCS_SUBDIR), { overwrite: true })

      zipPath = `${packageFolder}.zip`

      const zipOk = await ZipUtil.zipFolder(packageFolder, zipPath)

      if (!zipOk) {

        return { ok: false, mode: 'full', message: useHarmonyPhysicalWorkDir ? 'Harmony 平台同步包 ZIP 打包失败或未实现' : '打包同步包失败' }

      }

  returnedPath = zipPath
  return { ok: true, mode: 'full', path: zipPath, artifactFormat: 'zip' }

    } catch (e) {

      __f__('error','at services/export/export-import.uts:177',`[ExportImportService] exportPackageZip error: ${e}`)

      return { ok: false, mode: 'full', message: (e as Error).message }

    } finally {

      if (filteredDbPath != '') {

        if (filteredDbPath != returnedPath) {
          await ExportImportService.cleanupExportWorkPath(filteredDbPath)
        }

      }

      if (packageFolder != '') {

        await ExportImportService.cleanupExportWorkPath(packageFolder)

      }

    }

  }

  static async getMaxEntityChangeTime(cutoffMs: number = 0): Promise<number> {

    if (!DB.isReady) return 0

    try {

      const tables = await ExportImportService.listUserTables()

      let maxChangedAt = 0

      for (let i = 0; i < tables.length; i++) {

        const table = tables[i]

        if (table.startsWith('sqlite_')) continue

        const columns = await ExportImportService.getTableColumns(table, '')

        const changeExpr = ExportImportService.buildEffectiveChangeExpr(columns)

        if (changeExpr == '') continue

        let sql = `SELECT MAX(${changeExpr}) AS max_ts FROM ${table}`

        const args = [] as SqlArgs

        const whereParts = [] as string[]

        if (cutoffMs > 0) {

          whereParts.push(`${changeExpr} >= ?`)

          args.push(cutoffMs)

        }

        if (table == 'user_kv') {

          whereParts.push(`COALESCE(k, '') != ?`)

          args.push(SYNC_DEVICE_ID_KEY)

        }

        if (whereParts.length > 0) {

          sql += ` WHERE ${whereParts.join(' AND ')}`

        }

        const rows = await DB.query(sql, args)

        if (rows.length == 0) continue

        const raw = rows[0].get('max_ts')

        const ts = raw == null ? 0 : parseInt(raw.toString())

        if (!isNaN(ts) && ts > maxChangedAt) maxChangedAt = ts

      }

      return maxChangedAt

    } catch (_e) {

      return 0

    }

  }

  static async getMaxEntityChangeTimeBefore(cutoffMs: number): Promise<number> {

    if (!DB.isReady || cutoffMs <= 0) return 0

    try {

      const tables = await ExportImportService.listUserTables()

      let maxChangedAt = 0

      for (let i = 0; i < tables.length; i++) {

        const table = tables[i]

        if (table.startsWith('sqlite_')) continue

        const columns = await ExportImportService.getTableColumns(table, '')

        const changeExpr = ExportImportService.buildEffectiveChangeExpr(columns)

        if (changeExpr == '') continue

        let sql = `SELECT MAX(${changeExpr}) AS max_ts FROM ${table}`

        const args = [] as SqlArgs

        const whereParts = [] as string[]

        whereParts.push(`${changeExpr} < ?`)

        args.push(cutoffMs)

        if (table == 'user_kv') {

          whereParts.push(`COALESCE(k, '') != ?`)

          args.push(SYNC_DEVICE_ID_KEY)

        }

        sql += ` WHERE ${whereParts.join(' AND ')}`

        const rows = await DB.query(sql, args)

        if (rows.length == 0) continue

        const raw = rows[0].get('max_ts')

        const ts = raw == null ? 0 : parseInt(raw.toString())

        if (!isNaN(ts) && ts > maxChangedAt) maxChangedAt = ts

      }

      return maxChangedAt

    } catch (_e) {

      return 0

    }

  }

  private static async exportDbWindow(windowMode: ExportPackageWindowMode, cutoffMs: number, preferPhysicalOutput: boolean = false): Promise<ExportResult> {

    const base = await ExportImportService.exportDbOnly(windowMode != 'all' && !preferPhysicalOutput, preferPhysicalOutput)

    if (!base.ok || base.path == null || base.path.toString().trim() == '') return base

    if (windowMode == 'all') return base

    const ok = await ExportImportService.filterExportedDbWindow(base.path.toString(), windowMode, cutoffMs)

    if (ok) return base

    await FileUtil.removeFile(base.path.toString())

    return { ok: false, mode: 'db_only', message: '裁剪同步数据库失败' }

  }

  private static async filterExportedDbWindow(exportedDbPath: string, windowMode: ExportPackageWindowMode, cutoffMs: number): Promise<boolean> {

    if (windowMode == 'all') return true

    if (cutoffMs <= 0) return true

    // #ifdef APP-HARMONY
    return await ExportImportService.filterHarmonyExportedDbWindow(exportedDbPath, windowMode, cutoffMs)
    // #endif

    let attached = false
    let attachDbPath = exportedDbPath
    let shouldPersistAttachDb = false
    let shouldCleanupAttachDb = false

    const attachAlias = 'zemo_pkg'

    const detachSql = `DETACH DATABASE ${attachAlias}`

    try {

      const attachTarget = await ExportImportService.prepareAttachDbPath(exportedDbPath)
      attachDbPath = attachTarget.path
      shouldPersistAttachDb = attachTarget.persistBack
      shouldCleanupAttachDb = attachTarget.persistBack

      __f__('log','at services/export/export-import.uts:446',`[ExportImportService] filterExportedDbWindow attach source=${exportedDbPath} seed=${attachTarget.seedPath} target=${attachDbPath} persistBack=${shouldPersistAttachDb}`)

      const attachSql = `ATTACH DATABASE '${attachDbPath.replace(/'/g, "''")}' AS ${attachAlias}`

      await DB.beginTransaction()

      const attachedOk = await DB.exec(attachSql)

      if (!attachedOk) throw new Error('attach package db failed')

      attached = true

      const tables = await ExportImportService.listUserTables()

      for (let i = 0; i < tables.length; i++) {

        const table = tables[i]

        if (table.startsWith('sqlite_')) continue

        const columns = await ExportImportService.getTableColumns(table, attachAlias)

        const deletePlan = ExportImportService.buildWindowDeletePlan(attachAlias, table, columns, windowMode, cutoffMs)

        if (deletePlan.sql != '') {

          const deleteOk = await DB.exec(deletePlan.sql, deletePlan.args)

          if (!deleteOk) throw new Error(`filter package table failed: ${table}`)

        }

        if (table == 'user_kv') {

          const sanitizeOk = await DB.exec(`DELETE FROM ${attachAlias}.user_kv WHERE COALESCE(k, '') = ?`, [SYNC_DEVICE_ID_KEY])

          if (!sanitizeOk) throw new Error('sanitize package user_kv failed')

        }

      }

      const detachOk = await DB.exec(detachSql)

      if (!detachOk) throw new Error('detach package db failed')

      attached = false

      if (shouldPersistAttachDb) {
        const persistOk = await ExportImportService.persistAttachDbPath(attachDbPath, exportedDbPath)
        if (!persistOk) throw new Error('persist package db failed')
      }

      await DB.setTransactionSuccessful()

      return true

    } catch (e) {

      __f__('error','at services/export/export-import.uts:281',`[ExportImportService] filterExportedDbWindow error: ${e}`)

      return false

    } finally {

      if (attached) {

        try { await DB.exec(detachSql) } catch (_e0) {}

      }

      if (shouldCleanupAttachDb) {
        ExportImportService.cleanupAttachDbPath(attachDbPath, exportedDbPath)
      }

      await DB.endTransaction()

    }

  }

  private static async filterHarmonyExportedDbWindow(exportedDbPath: string, windowMode: ExportPackageWindowMode, cutoffMs: number): Promise<boolean> {

    let workDbPath = exportedDbPath
    let shouldPersistWorkDb = false
    let shouldCleanupWorkDb = false
    let tempStore: relationalStore.RdbStore | null = null
    let committed = false

    try {

      const attachTarget = await ExportImportService.prepareAttachDbPath(exportedDbPath)
      workDbPath = attachTarget.path
      shouldPersistWorkDb = attachTarget.persistBack
      shouldCleanupWorkDb = attachTarget.persistBack

      __f__('log','at services/export/export-import.uts:446',`[ExportImportService] filter window source=${exportedDbPath} seed=${attachTarget.seedPath} workDb=${workDbPath} persistBack=${shouldPersistWorkDb}`)

      tempStore = await ExportImportService.openHarmonyTempStore(workDbPath)
      if (tempStore == null) throw new Error('open package temp db failed')

      tempStore.beginTransaction()

      const tables = await ExportImportService.listHarmonyStoreTables(tempStore)

      for (let i = 0; i < tables.length; i++) {

        const table = tables[i]

        if (table.startsWith('sqlite_')) continue

        const columns = await ExportImportService.getHarmonyStoreTableColumns(tempStore, table)

        const deletePlan = ExportImportService.buildWindowDeletePlan(table, columns, windowMode, cutoffMs)

        if (deletePlan.sql != '') {

          const deleteOk = await ExportImportService.execHarmonyStore(tempStore, deletePlan.sql, deletePlan.args)

          if (!deleteOk) throw new Error(`filter package table failed: ${table}`)

        }

        if (table == 'user_kv') {

          const sanitizeOk = await ExportImportService.execHarmonyStore(tempStore, 'DELETE FROM user_kv WHERE COALESCE(k, "") = ?', [SYNC_DEVICE_ID_KEY])

          if (!sanitizeOk) throw new Error('sanitize package user_kv failed')

        }

      }

      tempStore.commit()
      committed = true

      if (shouldPersistWorkDb) {
        const persistOk = await ExportImportService.persistAttachDbPath(workDbPath, exportedDbPath)
        if (!persistOk) throw new Error('persist package db failed')
      }

      return true

    } catch (e) {

      __f__('error','at services/export/export-import.uts:281',`[ExportImportService] filterHarmonyExportedDbWindow error: ${e}`)

      return false

    } finally {

      try {
        if (tempStore != null && !committed) tempStore.rollBack()
      } catch (_e0) {}

      try {
        const closable = tempStore as any
        if (closable != null && closable.close != null) closable.close()
      } catch (_e1) {}

      if (shouldCleanupWorkDb) {
        ExportImportService.cleanupAttachDbPath(workDbPath, exportedDbPath)
      }

    }

  }

  private static buildWindowDeletePlan(tableRef: string, columns: Set<string>, windowMode: ExportPackageWindowMode, cutoffMs: number): { sql: string, args: SqlArgs } {

    const args = [] as SqlArgs

    const changeExpr = ExportImportService.buildEffectiveChangeExpr(columns)

    if (changeExpr == '') {

      if (windowMode == 'since_cutoff') {

        return { sql: `DELETE FROM ${tableRef}`, args }

      }

      return { sql: '', args }

    }

    const comparator = windowMode == 'before_cutoff' ? '>=' : '<'

    args.push(cutoffMs)

    return {

      sql: `DELETE FROM ${tableRef} WHERE ${changeExpr} ${comparator} ?`,

      args,

    }

  }

  private static buildEffectiveChangeExpr(columns: Set<string>): string {

    const hasCreatedAt = columns.has('created_at')

    const hasUpdatedAt = columns.has('updated_at')

    const hasTombstoneAt = columns.has('tombstone_at')

    if (!hasCreatedAt && !hasUpdatedAt && !hasTombstoneAt) return ''

    const parts = [] as string[]

    if (hasTombstoneAt) parts.push(`NULLIF(CAST(tombstone_at AS INTEGER), 0)`)

    if (hasUpdatedAt) parts.push(`NULLIF(CAST(updated_at AS INTEGER), 0)`)

    if (hasCreatedAt) parts.push(`NULLIF(CAST(created_at AS INTEGER), 0)`)

    parts.push('0')

    return `COALESCE(${parts.join(', ')})`

  }

  private static async getTableColumns(table: string, attachAlias: string = ''): Promise<Set<string>> {

    const prefix = attachAlias == '' ? '' : `${attachAlias}.`

    const rows = await DB.query(`PRAGMA ${prefix}table_info(${table})`)

    const set = new Set<string>()

    for (let i = 0; i < rows.length; i++) {

      const nameVal = rows[i].get('name')

      const name = nameVal == null ? '' : nameVal.toString()

      if (name != '') set.add(name)

    }

    return set

  }

  private static async openHarmonyTempStore(dbPath: string): Promise<relationalStore.RdbStore | null> {

    try {
      const normalizedPath = (dbPath ?? '').toString().trim().replace(/\\/g, '/')
      const fileNameStart = normalizedPath.lastIndexOf('/')
      if (normalizedPath == '' || fileNameStart < 0 || fileNameStart >= normalizedPath.length - 1) return null
      const ctx = getContext() as common.UIAbilityContext
      const storeConfig: relationalStore.StoreConfig = {
        name: normalizedPath.substring(fileNameStart + 1),
        securityLevel: relationalStore.SecurityLevel.S1,
      }
      return await relationalStore.getRdbStore(ctx, storeConfig)
    } catch (e) {
      const err = e as BusinessError
      __f__('error','at services/export/export-import.uts:340',`[ExportImportService] openHarmonyTempStore error code=${err.code} message=${err.message} path=${dbPath}`)
      return null
    }

  }

  private static async execHarmonyStore(store: relationalStore.RdbStore, sql: string, args: SqlArgs | null = null): Promise<boolean> {

    try {
      const safeArgs = DB.normalizeArgs(args)
      if (safeArgs.length > 0) await store.executeSql(sql, safeArgs as Array<any>)
      else await store.executeSql(sql)
      return true
    } catch (e) {
      const err = e as BusinessError
      __f__('error','at services/export/export-import.uts:351',`[ExportImportService] execHarmonyStore error code=${err.code} message=${err.message} sql=${sql}`)
      return false
    }

  }

  private static async queryHarmonyStore(store: relationalStore.RdbStore, sql: string, args: SqlArgs | null = null): Promise<Array<Map<string, any | null>>> {

    const result = [] as Array<Map<string, any | null>>
    let rs: relationalStore.ResultSet | null = null
    try {
      const safeArgs = DB.normalizeArgs(args)
      if (safeArgs.length > 0) rs = await store.querySql(sql, safeArgs as Array<any>)
      else rs = await store.querySql(sql)
      if (rs != null && rs.rowCount > 0) {
        const colCount = rs.columnCount
        const colNames = rs.columnNames
        while (rs.goToNextRow()) {
          const row = new Map<string, any | null>()
          for (let i = 0; i < colCount; i++) {
            const name = colNames[i]
            if (rs.isColumnNull(i)) row.set(name, null)
            else row.set(name, rs.getString(i))
          }
          result.push(row)
        }
      }
    } catch (e) {
      const err = e as BusinessError
      __f__('error','at services/export/export-import.uts:372',`[ExportImportService] queryHarmonyStore error code=${err.code} message=${err.message} sql=${sql}`)
    } finally {
      if (rs != null) rs.close()
    }
    return result

  }

  private static async listHarmonyStoreTables(store: relationalStore.RdbStore): Promise<string[]> {

    const rows = await ExportImportService.queryHarmonyStore(store, `SELECT name FROM sqlite_master WHERE type='table' ORDER BY name ASC`)
    const tables = [] as string[]
    for (let i = 0; i < rows.length; i++) {
      const nameVal = rows[i].get('name')
      const name = nameVal == null ? '' : nameVal.toString()
      if (name != '') tables.push(name)
    }
    return tables

  }

  private static async getHarmonyStoreTableColumns(store: relationalStore.RdbStore, table: string): Promise<Set<string>> {

    const rows = await ExportImportService.queryHarmonyStore(store, `PRAGMA table_info(${table})`)
    const set = new Set<string>()
    for (let i = 0; i < rows.length; i++) {
      const nameVal = rows[i].get('name')
      const name = nameVal == null ? '' : nameVal.toString()
      if (name != '') set.add(name)
    }
    return set

  }



  /**

   * 纯数据库导入（增量合并，不覆盖原数据）�?

   * Android：ATTACH + INSERT OR IGNORE�?

   * Harmony：将导入库拷贝到 rdb 目录并以新名字打开，再逐表插入�?

   */

  static async importDbOnly(importDbPath: string, context: any | null = null): Promise<ExportResult> {

    try {

      await FileUtil.ensureRuntimeDirs()



      // 确保当前库已初始�?

      await DBInit.run(context)



      const ok = await ExportImportService.mergeDatabase(importDbPath, context)

      if (!ok) return { ok: false, mode: 'db_only', message: '增量合并失败' }

      const schemaOk = await DB.ensureSchema()
      if (!schemaOk) return { ok: false, mode: 'db_only', message: '导入后数据库迁移失败' }



      return { ok: true, mode: 'db_only', message: '导入完成（增量合并）' }

    } catch (e) {

      __f__('error','at services/export/export-import.uts:131',`[ExportImportService] importDbOnly error: ${e}`)

      return { ok: false, mode: 'db_only', message: (e as Error).message }

    }

  }



  /**

   * 完整导出（数据库 + 资源）�?

   * 资源目录来自 RUNTIME_ASSETS_DIR（用户上�?缓存的图片与音频）�?

   * Android 优先打包 zip；其他平台暂返回导出目录路径（可后续补齐 zip 实现）�?

   */

  static async exportFull(): Promise<ExportResult> {

    try {

      await FileUtil.ensureRuntimeDirs()



      const time = formatDateForFile(new Date())

      const exportFolder = joinPath(RUNTIME_FULL_EXPORT_DIR, `${EXPORT_FULL_PREFIX}${time}`)

      await FileUtil.ensureDir(exportFolder)



      // 1) 导出 DB

      const dbRes = await ExportImportService.exportDbOnly()

      if (!dbRes.ok || dbRes.path == null) return { ok: false, mode: 'full', message: dbRes.message ?? '导出DB失败' }

      const dbDest = joinPath(exportFolder, getCurrentDbName())

      await FileUtil.copyFile(dbRes.path, dbDest, { overwrite: true })



      // 2) 复制资源（当前模板不做强绑定扫描，直接复制整�?runtime assets�?

      // 这里保持“数据库只存路径”，资源仍在独立目录�?

      // 只导�?images/, music/, videos/, note_docs/，避免把 db_export/full_export 自己再导出导致递归膨胀�?

      await FileUtil.copyDir(RUNTIME_IMAGES_DIR, joinPath(exportFolder, FULL_EXPORT_IMAGES_SUBDIR), { overwrite: true })

      await FileUtil.copyDir(RUNTIME_MUSIC_DIR, joinPath(exportFolder, FULL_EXPORT_MUSIC_SUBDIR), { overwrite: true })

      await FileUtil.copyDir(RUNTIME_VIDEOS_DIR, joinPath(exportFolder, FULL_EXPORT_VIDEOS_SUBDIR), { overwrite: true })

      await FileUtil.copyDir(RUNTIME_NOTE_DOCS_DIR, joinPath(exportFolder, FULL_EXPORT_NOTE_DOCS_SUBDIR), { overwrite: true })



      // 3) zip（若支持�?

      const zipPath = `${exportFolder}.zip`

      const zipOk = await ZipUtil.zipFolder(exportFolder, zipPath)

      if (zipOk) {

        return { ok: true, mode: 'full', path: zipPath }

      }



      return { ok: true, mode: 'full', path: exportFolder, message: '当前平台未实现 zip，已导出目录' }

    } catch (e) {

      __f__('error','at services/export/export-import.uts:172',`[ExportImportService] exportFull error: ${e}`)

      return { ok: false, mode: 'full', message: (e as Error).message }

    }

  }



  /**

   * 完整恢复（覆盖式）：

   * - DB：直接覆盖当�?ZeMo.db（复�?BackupService.restoreDatabase�?

   * - 资源：覆�?runtime images/music

   * 支持�?

   * - Android: 传入 zip 路径会先解压

   * - 传入目录：直接读取目�?

   */

  static async restoreFullReplace(path: string, context: any | null = null): Promise<ExportResult> {

    try {

      await FileUtil.ensureRuntimeDirs()





      if (path.toLowerCase().endsWith('.zip')) {

        const time = formatDateForFile(new Date())

        const destFolder = joinPath(RUNTIME_FULL_EXPORT_DIR, `restore_${time}`)

        const unzipOk = await ZipUtil.unzipFile(path, destFolder)

        if (!unzipOk) return { ok: false, mode: 'full', message: '解压失败（zip文件可能损坏）' }

        return await ExportImportService.restoreFullReplaceFromFolder(destFolder, context)

      }





      return await ExportImportService.restoreFullReplaceFromFolder(path, context)

    } catch (e) {

      __f__('error','at services/export/export-import.uts:201',`[ExportImportService] restoreFullReplace error: ${e}`)

      return { ok: false, mode: 'full', message: (e as Error).message }

    }

  }



  private static async restoreFullReplaceFromFolder(folderPath: string, context: any | null = null): Promise<ExportResult> {

    // 1) DB 覆盖

    const dbPath = joinPath(folderPath, getCurrentDbName())

    const dbExists = await FileUtil.exists(dbPath)

    if (!dbExists) return { ok: false, mode: 'full', message: '未找到目录内的ZeMo.db' }



    const restoreMsg = await BackupService.restoreDatabase(dbPath, null)

    if (!restoreMsg.toString().startsWith('恢复成功')) {

      return { ok: false, mode: 'full', message: restoreMsg }

    }



    // 2) 资源覆盖

    const importImagesDir = joinPath(folderPath, FULL_EXPORT_IMAGES_SUBDIR)

    const importMusicDir = joinPath(folderPath, FULL_EXPORT_MUSIC_SUBDIR)

    const importVideosDir = joinPath(folderPath, FULL_EXPORT_VIDEOS_SUBDIR)

    const importDocsDir = joinPath(folderPath, FULL_EXPORT_NOTE_DOCS_SUBDIR)



    const imagesExists = await FileUtil.exists(importImagesDir)

    if (imagesExists) {

      await FileUtil.copyDir(importImagesDir, RUNTIME_IMAGES_DIR, { overwrite: true })

    }



    const musicExists = await FileUtil.exists(importMusicDir)

    if (musicExists) {

      await FileUtil.copyDir(importMusicDir, RUNTIME_MUSIC_DIR, { overwrite: true })

    }



    const videosExists = await FileUtil.exists(importVideosDir)

    if (videosExists) {

      await FileUtil.copyDir(importVideosDir, RUNTIME_VIDEOS_DIR, { overwrite: true })

    }



    const docsExists = await FileUtil.exists(importDocsDir)

    if (docsExists) {

        await FileUtil.copyDir(importDocsDir, RUNTIME_NOTE_DOCS_DIR, { overwrite: true })

    }



    return { ok: true, mode: 'full', message: '还原完成（直接覆盖）' }

    }





    static async importFull(path: string, context: any | null = null): Promise<ExportResult> {

      try {





      // Allow passing a zip directly (exportFull on Android prefers zip).

      // [Fix]: Handle both local paths (file://...) and temp paths (.tmp). 

      // If the file exists and is likely the downloaded backup, try unzip logic.

      const isZip = path.toLowerCase().endsWith('.zip') || path.toLowerCase().endsWith('.tmp')

      

      if (isZip) {

        // Double check it is a file not a directory

        const isDir = await FileUtil.isDir(path)

        if (!isDir) {

            __f__('log','at services/export/export-import.uts:260',`[ExportImportService] Treating path as ZIP: ${path}`)

            const time = formatDateForFile(new Date())

            const destFolder = joinPath(RUNTIME_FULL_EXPORT_DIR, `import_${time}`)

            await FileUtil.ensureDir(destFolder)

            

            // Try unzip

            // Optimize: for .tmp files, prefer native rename or direct usage (but ZipFile might need extension)

            // But we'll stick to logic: Rename/Copy to .zip to be safe

            let zipPath = path

            let renamed = false

            

            if (!path.toLowerCase().endsWith('.zip')) {

                zipPath = path + '.zip'

              await FileUtil.copyFile(path, zipPath, { overwrite: true })

              renamed = true

            }

            

            const unzipOk = await ZipUtil.unzipFile(zipPath, destFolder)

            if (!unzipOk) return { ok: false, mode: 'full', message: '解压失败（文件可能损坏）' }

            

            // Cleanup temp rename if created

            if (renamed && zipPath != path) {

                try{ await FileUtil.removeFile(zipPath) } catch(_e){}

            }

            

            return await ExportImportService.importFull(destFolder, context)

        }

      }





      // 简化：要求传入目录

      // [Fix]: Intelligent folder detection (handle nested unzip folders)

      let effectivePath = path

      let dbPath = joinPath(effectivePath, getCurrentDbName())

      let dbExists = await FileUtil.exists(dbPath)

      

      if (!dbExists) {

        // [Fix]: Robust nested folder detection (Recursive)

        // Only going 2 levels deep to avoid performance hit

        __f__('log','at services/export/export-import.uts:312',`[ExportImportService] DB not at root. Scanning subfolders of: ${effectivePath}`)

        

        

        

        const foundFolder = await ExportImportService.findDb(effectivePath, 0)

        if (foundFolder != null) {

            effectivePath = foundFolder

            dbPath = joinPath(effectivePath, getCurrentDbName())

            dbExists = true

            __f__('log','at services/export/export-import.uts:321',`[ExportImportService] Found DB in subfolder: ${effectivePath}`)

        }

      }



      if (!dbExists) {

        // Log details about "effectivePath" to see what we actually extracted

        const list = await FileUtil.listDirRecursive(path) // Assume we need a tool or just simple list

        // Simple list of root for message

        const listRoot = await FileUtil.readDir(path)

        __f__('error','at services/export/export-import.uts:330',`[ExportImportService] Import failed. Root list: ${JSON.stringify(listRoot)}`)

        return { ok: false, mode: 'full', message: '未找到 ZeMo.db。请检查备份文件。' }

      }



      const dbRes = await ExportImportService.importDbOnly(dbPath, context)

      if (!dbRes.ok) return { ok: false, mode: 'full', message: dbRes.message ?? '导入DB失败' }



      // 复制资源：按“存在则跳过”策略复制导出目录内的资源到 runtime�?

      const importImagesDir = joinPath(effectivePath, FULL_EXPORT_IMAGES_SUBDIR)

      const importMusicDir = joinPath(effectivePath, FULL_EXPORT_MUSIC_SUBDIR)

      const importVideosDir = joinPath(effectivePath, FULL_EXPORT_VIDEOS_SUBDIR)

      const importDocsDir = joinPath(effectivePath, FULL_EXPORT_NOTE_DOCS_SUBDIR)



      const imagesExists = await FileUtil.exists(importImagesDir)

      if (imagesExists) {

        await FileUtil.copyDir(importImagesDir, RUNTIME_IMAGES_DIR, { overwrite: false })

      }



      const musicExists = await FileUtil.exists(importMusicDir)

      if (musicExists) {

        await FileUtil.copyDir(importMusicDir, RUNTIME_MUSIC_DIR, { overwrite: false })

      }

      

      const videosExists = await FileUtil.exists(importVideosDir)

      if (videosExists) {

        await FileUtil.copyDir(importVideosDir, RUNTIME_VIDEOS_DIR, { overwrite: false })

      }



      const docsExists = await FileUtil.exists(importDocsDir)

      if (docsExists) {

        await FileUtil.copyDir(importDocsDir, RUNTIME_NOTE_DOCS_DIR, { overwrite: false })

      }



      return { ok: true, mode: 'full', message: '完整导入完成' }

    } catch (e) {

      __f__('error','at services/export/export-import.uts:365',`[ExportImportService] importFull error: ${e}`)

      return { ok: false, mode: 'full', message: (e as Error).message }

    }

  }



  

  private static async findDb(dir: string, depth: number): Promise<string | null> { if (depth > 2) return null; const items = await FileUtil.readDir(dir); if (items.includes(getCurrentDbName())) return dir; for (let i = 0; i < items.length; i++) { const name = items[i]; if (name.startsWith('.') || name == '__MACOSX') continue; const sub = joinPath(dir, name); const isDir = await FileUtil.isDir(sub); if (isDir) { const found = await ExportImportService.findDb(sub, depth + 1); if (found != null) return found; } } return null; }

  private static async getCurrentDbFilePath(context: any | null = null): Promise<string | null> {

    try {

      const dbPath = DB.getDatabasePath()

      if (dbPath != null && dbPath.toString().trim() != '') return dbPath.toString()

    } catch (_e0) {}

    // #ifdef APP-ANDROID
    try {

      const ctx = io.dcloud.uts.UTSAndroid.getAppContext()

      if (ctx == null) return null

      const dbFile = ctx.getDatabasePath(getCurrentDbName())

      return dbFile.getAbsolutePath().toString()

    } catch (_) {

      return null

    }
    // #endif

    return null

  }

  private static async prepareAttachDbPath(exportedDbPath: string): Promise<{ path: string, persistBack: boolean, seedPath: string }> {

    const directPath = ExportImportService.resolveAttachDbPath(exportedDbPath)

    if (directPath != exportedDbPath) {
      return { path: directPath, persistBack: false, seedPath: exportedDbPath }
    }

    // #ifdef APP-HARMONY
    if (exportedDbPath.indexOf('unifile://') == 0) {
      const reservedSeedPath = ExportImportService.getReservedHarmonyExportSeedPath()
      if (reservedSeedPath != '') {
        return { path: reservedSeedPath, persistBack: true, seedPath: reservedSeedPath }
      }

      const seedDbPath = ExportImportService.getHarmonyAttachSeedDbPath()
      const slash = seedDbPath.lastIndexOf('/')
      if (slash > 0) {
        const tempAttachPath = `${seedDbPath.substring(0, slash)}/zemo_pkg_attach_${Date.now()}.db`
        const copied = ExportImportService.copyHarmonyBinaryFile(seedDbPath, tempAttachPath)
        if (copied) {
          return { path: tempAttachPath, persistBack: true, seedPath: seedDbPath }
        }
      }
    }
    // #endif

    return { path: directPath, persistBack: false, seedPath: exportedDbPath }

  }

  private static shouldUseHarmonyPhysicalPackageWorkDir(): boolean {

    // #ifdef APP-HARMONY
    return true
    // #endif

    return false

  }

  private static buildHarmonyPhysicalDbExportPath(fileName: string): string {

