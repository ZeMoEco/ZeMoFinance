	// ========================================================================
	// 7. 通用工具函数 (供 UI 层复用)
	// ========================================================================

	export type LyricLine = {
		time : number
		text : string
	}

	export function parseLyric(lrc : string) : LyricLine[] {
		const result : LyricLine[] = [];
		if (lrc == "") return result;

		const cleanLrc = lrc.replace(/\\n/g, '\n');
		const lines = cleanLrc.split('\n');
		const timeReg = /\[(\d{1,3}):(\d{2})(?:\.(\d{1,3}))?\]/;

		lines.forEach(line => {
			const matchReg = timeReg.exec(line);
			if (matchReg != null) {
				const fullMatch = matchReg[0];
				if (fullMatch != null) {
					const min = parseInt(matchReg[1] ?? "0");
					const sec = parseInt(matchReg[2] ?? "0");
					let ms = 0;
					const msStr = matchReg[3] ?? "0";

					if (msStr.length == 2) ms = parseInt(msStr) * 10;
					else if (msStr.length == 3) ms = parseInt(msStr);
					else ms = parseInt(msStr);

					const time = min * 60 + sec + ms / 1000.0;
					const text = line.replace(fullMatch, "").trim();

					if (text.length > 0) {
						result.push({ time, text } as LyricLine);
					}
				}
			}
		});

		if (result.length == 0) {
			result.push({ time: 0, text: "暂无滚动歌词" } as LyricLine);
		}
		return result;
	}

	export function calcCurrentLyricIndex(lines : LyricLine[], currentTime : number) : number {
		if (lines.length == 0) return -1;
		for (let i = lines.length - 1; i >= 0; i--) {
			if (currentTime >= lines[i].time) {
				return i;
			}
		}
		return -1;
	}

	export function formatTime(time : number) : string {
		if (Number.isNaN(time) || time < 0) return '00:00';
		const t = Math.floor(time);
		const minutes = Math.floor(t / 60);
		const seconds = Math.floor(t % 60);

		const minStr = minutes < 10 ? "0" + minutes : minutes.toString();
		const secStr = seconds < 10 ? "0" + seconds : seconds.toString();

		return `${minStr}:${secStr}`;
	}

	export function toggleFavoriteState(song : MusicSong) : boolean {
		if (isFavorite(song.id)) {
			removeFromFavorites(song.id);
			uni.showToast({ title: "已取消收藏", icon: "none" });
			return false;
		} else {
			addToFavorites(song);
			uni.showToast({ title: "已收藏", icon: "success" });
			return true;
		}
	}

	// ========================================================================
	// 8. 智能播放接口 (核心复用逻辑)
	// ========================================================================

	export async function smartPlay(song : MusicSong, contextPlaylist ?: MusicSong[]) {
		console.log(`🚀 [SmartPlay] ${song.title}`);

		if (musicState.currentSong?.id == song.id) {
			togglePlay();
			return;
		}

		if (contextPlaylist != null) {
			musicState.playlist = [...contextPlaylist];
			const idx = musicState.playlist.findIndex(s => s.id == song.id);
			if (idx >= 0) musicState.currentIndex = idx;
		}

		if (song.coverImage.startsWith('http://')) {
			song.coverImage = song.coverImage.replace('http://', 'https://');
		}

		if (song.source == 'local' || (song.playUrl != "" && song.playUrl.startsWith("http"))) {
			playSong(song);
			return;
		}

		uni.showLoading({ title: "极速解析...", mask: true });

		try {
			const res = await autoResolveSongUrl(song);
			if (res != null && res.url != "" && res.url.startsWith("http")) {
				console.log(`✅ 解析成功: ${res.url}`);

				song.playUrl = res.url;
				if (res.sourceId != "") song.source = res.sourceId;

				playSong(song);
			} else {
				throw new Error("解析地址无效");
			}
		} catch (e) {
			console.error("❌ SmartPlay Error:", e);
			uni.showToast({ title: "暂无播放源", icon: "none" });
		} finally {
			uni.hideLoading();
		}
	}

	export async function autoResolveSongUrl(song : MusicSong) : Promise<ResolveResult | null> {
		if (!_isLoaded) getMusicSources();

		const candidates : MusicSource[] = [];
		const addedIds = new Set<string>();

		// A. 优先尝试 song.source 指定的源
		if (song.source != "" && song.source != "local") {
			const s = _allSources.find(src => src.id == song.source);
			if (s != null) { candidates.push(s); addedIds.add(s.id); }
			else {
				const tag = song.source.toLowerCase();
				const fuzzy = _allSources.find(src => src.name.toLowerCase().includes(tag) && src.script.trim() != "");
				if (fuzzy != null && !addedIds.has(fuzzy.id)) { candidates.push(fuzzy); addedIds.add(fuzzy.id); }
			}
		}

		// B. 尝试所有可用的插件源 (兜底)
		_allSources.forEach(s => {
			if (s.type == 'plugin' && !addedIds.has(s.id) && s.script.trim() != "") {
				candidates.push(s);
				addedIds.add(s.id);
			}
		});

		// C. 逐个尝试
		for (const source of candidates) {
			try {
				let command: any;
				// #ifdef APP-ANDROID
				const cmdObj = new UTSJSONObject();
				cmdObj.set('action', 'get_media');
				cmdObj.set('song', song.httpHeaders);
				cmdObj.set('script', source.script);
				command = cmdObj;
				// #endif
				
				// #ifndef APP-ANDROID
				command = {
					action: "get_media",
					song: song.httpHeaders,
					script: source.script
				};
				// #endif
				
				console.log(`⏳ 尝试源: ${source.name} (${source.id})`);

				const res = await executePluginCommand(command);

				if (res != null) {
					let finalUrl = "";
					// #ifdef APP-ANDROID
					if (res instanceof UTSJSONObject) {
						finalUrl = (res['url'] ?? "").toString();
					} else {
						finalUrl = res.toString();
					}
					// #endif
					// #ifndef APP-ANDROID
					finalUrl = res.toString();
					// #endif

					if (finalUrl != "" && finalUrl.startsWith("http")) {
						return { url: finalUrl, sourceId: source.id } as ResolveResult;
					}
				}
			} catch (e) { }
		}
		return null;
	}