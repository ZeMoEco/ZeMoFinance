		width: 100%;
		height: 100%;
		background-color: transparent;
	}

	.container {
		height: 100%;
		padding: 18px;
		background-color: transparent;
	}

	.header {
		margin-top: 20px;
		margin-bottom: 16px;
	}

	.page-title {
		font-size: 26px;
		font-weight: bold;
		color: #173638;
	}

	.page-subtitle {
		font-size: 13px;
		color: #5f7476;
		margin-top: 8px;
	}

	.card {
		background-color: rgba(255, 255, 255, 0.76);
		border-radius: 18px;
		padding: 18px;
		margin-bottom: 14px;
		border-width: 1px;
		border-color: rgba(255, 255, 255, 0.74);
		box-shadow: 0 10px 26px rgba(28, 54, 66, 0.12);
	}

	.card-header {
		flex-direction: row;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 12px;
	}

	.card-heading {
		flex: 1;
		padding-right: 10px;
	}

	.card-title {
		font-size: 18px;
		font-weight: bold;
		color: #173638;
	}

