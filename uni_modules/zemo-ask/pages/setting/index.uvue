	}

	.quick-action-main {
		flex: 1;
		padding-right: 12px;
	}

	.quick-action-title {
		font-size: 15px;
		font-weight: bold;
		color: #173638;
	}

	.quick-action-link {
		font-size: 11px;
		color: #6d7f82;
