		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		padding: 13px 0;
		border-bottom-width: 1px;
		border-bottom-color: rgba(210, 220, 224, 0.82);
	}

	.setting-item-last {
		border-bottom-width: 0;
	}

	.setting-left {
		flex: 1;
		padding-right: 12px;
