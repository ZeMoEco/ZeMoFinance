// #ifdef APP-ANDROID
// --- 全局变量 ---
let gWinMgr : WindowManager | null = null;
let gContainer : FrameLayout | null = null;
let gParams : WindowManager.LayoutParams | null = null;
let gMenuContainer : LinearLayout | null = null;
let gMsgContainer : TextView | null = null;
let gLottieView : LottieAnimationView | null = null;
let gVibrator : Vibrator | null = null;
// 定义一个模块作用域内的私有变量，用于存储唯一实例
let instance : SherpaEngine | null = null;
let gIsMenuShowing = false;
let gIsChatting = false;
let gIsRegistering = false;
let gIsLongPressExecuted = false;
let gJsCallback : ((action : string) => void) | null = null;
let isDragging = false;

const gHandler = new Handler(Looper.getMainLooper());
const TAG = "[ZeMo]";

