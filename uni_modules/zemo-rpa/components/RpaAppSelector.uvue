<template>
	<view class="app-selector-mask" @click="close">
		<view class="app-selector-content" @click.stop>
			<view class="selector-header">
				<text class="selector-title">Select App to Record</text>
				<view class="search-box">
					<text class="search-icon">🔍</text>
					<input class="search-input" placeholder="Search apps..." v-model="searchText" />
				</view>
			</view>
			
			<scroll-view class="app-list" scroll-y="true">
				<view class="app-item" v-for="(app, index) in filteredApps" :key="index" @click="selectApp(app)">
					<!-- Placeholder Icon -->
					<view class="app-icon-placeholder">
						<text class="app-icon-text">{{ app.appName.slice(0,1) }}</text>
					</view>
					<view class="app-info">
						<text class="app-name">{{ app.appName }}</text>
						<text class="app-pkg">{{ app.packageName }}</text>
					</view>
					<text class="app-arrow">➤</text>
				</view>
			</scroll-view>
            
            <view class="close-btn" @click="close">
                <text class="close-btn-text">Cancel</text>
            </view>
		</view>
	</view>
</template>

<script lang="uts">
    import { ZemoRpa } from '@/uni_modules/zemo-rpa';
    
    type AppData = {
        appName: string
        packageName: string
    }

	export default {
		name: "RpaAppSelector",
        emits: ['confirm', 'close'],
        data() {
            return {
                searchText: "",
                allApps: [] as AppData[]
            }
        },
        mounted() {
            this.loadApps();
        },
        computed: {
            filteredApps(): AppData[] {
                if (this.searchText == "") return this.allApps;
                const lower = this.searchText.toLowerCase();
                return this.allApps.filter((app: AppData) => {
                    return app.appName.toLowerCase().includes(lower) || 
                           app.packageName.toLowerCase().includes(lower);
                });
            }
        },
        methods: {
            close() {
                this.$emit('close');
            },
            loadApps() {
                const apps = ZemoRpa.getInstalledApps();
                 const res: AppData[] = [];
                 apps.forEach(item => {
                      // getInstalledApps returns Map<string, any> items, not UTSJSONObject
                      const obj = item as Map<string, any>;
                      const appName = (obj.get('appName') ?? "Unknown") as string;
                      const packageName = (obj.get('packageName') ?? "") as string;
                      res.push({ appName: appName, packageName: packageName } as AppData);
                 });
                 this.allApps = res;
            },
            selectApp(app: AppData) {
                this.$emit('confirm', app);
            }
        }
	}
</script>

