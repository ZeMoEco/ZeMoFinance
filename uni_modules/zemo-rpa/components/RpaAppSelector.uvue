	.app-selector-mask {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-color: rgba(0,0,0,0.5);
		justify-content: center;
		align-items: center;
		z-index: 9999;
        display: flex;
	}
	.app-selector-content {
		width: 320px;
		height: 500px;
		background-color: #ffffff;
		border-radius: 16px;
		display: flex;
		flex-direction: column;
		overflow: hidden;
        padding: 16px;
	}
    .selector-header {
        margin-bottom: 12px;
    }
    .selector-title {
        font-size: 18px;
        font-weight: bold;
        color: #333;
        margin-bottom: 12px;
        text-align: center;
    }
    .search-box {
        background-color: #f5f5f5;
        border-radius: 8px;
        flex-direction: row;
        align-items: center;
        padding: 8px 12px;
        display: flex;
    }
    .search-icon {
        margin-right: 8px;
        font-size: 14px;
    }
    .search-input {
        flex: 1;
        font-size: 14px;
        background-color: transparent;
    }
    .app-list {
        flex: 1;
        background-color: #fafafa;
        border-radius: 8px;
        padding: 4px;
    }
    .app-item {
        flex-direction: row;
        align-items: center;
        padding: 10px;
        border-bottom-width: 1px;
        border-bottom-color: #eee;
        background-color: #fff;
        margin-bottom: 4px;
        border-radius: 6px;
    }
    .app-icon-placeholder {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        background-color: #007aff;
        justify-content: center;
        align-items: center;
        margin-right: 12px;
    }
    .app-icon-text {
        color: white;
        font-size: 18px;
        font-weight: bold;
    }
    .app-info {
        flex: 1;
    }
    .app-name {
        font-size: 15px;
        color: #333;
        font-weight: 500;
    }
    .app-pkg {
        font-size: 12px;
        color: #999;
        margin-top: 2px;
    }
    .app-arrow {
        color: #ccc;
    }
    .close-btn {
        margin-top: 12px;
        align-items: center;
        padding: 10px;
        background-color: #f0f0f0;
        border-radius: 8px;
    }
    .close-btn-text {
        color: #666;
        font-size: 14px;
    }
</style>
