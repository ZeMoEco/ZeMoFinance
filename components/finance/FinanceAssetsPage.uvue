	.asset-deck-title-row { flex-direction: row; justify-content: space-between; align-items: center; padding: 0 18px; margin-bottom: 8px; }
	.asset-deck-title { font-size: 16px; font-weight: bold; color: #1b2846; }
	.asset-deck-total-wrap { flex-direction: row; align-items: center; padding-left: 12px; }
