	.asset-deck-card { flex-direction: row; justify-content: space-between; align-items: center; height: 143px; padding: 14px 14px 14px 11px; border-radius: 19px; background-color: #ffffff; border-width: 1px; border-color: #edf2f7; box-shadow: 0 14px 26px rgba(44,62,92,0.16); }
	.asset-card-rail { width: 44px; height: 112px; justify-content: flex-start; align-items: center; margin-right: 12px; border-radius: 15px; background-color: #f5f8fc; border-width: 1px; border-color: #e8eef6; padding-top: 9px; }
	.asset-card-icon { width: 30px; height: 30px; border-radius: 10px; background-color: #ffffff; border-width: 1px; border-color: #e7edf5; justify-content: center; align-items: center; margin-bottom: 7px; }
	.asset-card-icon-text { font-size: 15px; }
	.asset-card-vertical { font-size: 10px; line-height: 12px; color: #738099; font-weight: bold; text-align: center; }
	.asset-card-main { flex: 1; min-width: 0; }
	.asset-card-name { font-size: 14px; font-weight: bold; color: #1b2846; lines: 1; text-overflow: ellipsis; }
	.asset-card-sub { font-size: 12px; color: #8a97a0; margin-top: 5px; }
	.asset-card-right { align-items: flex-end; margin-left: 8px; }
	.asset-card-value { font-size: 14px; font-weight: bold; color: #1b2846; }
	.asset-card-value-credit { color: #e05050; }
	.asset-card-tag { font-size: 11px; color: #3b73d9; margin-top: 5px; }
	.investment-asset-scroll { width: 100%; height: 146px; flex-direction: row; white-space: nowrap; overflow: hidden; }
	.investment-asset-card { width: 150px; height: 132px; flex-shrink: 0; margin-right: 12px; padding: 12px; border-radius: 14px; background-color: rgba(255,255,255,0.60); border-width: 1px; border-color: rgba(255,255,255,0.72); box-shadow: 0 10px 22px rgba(44,62,92,0.09); }
	.investment-asset-name { font-size: 15px; font-weight: bold; color: #1b2846; lines: 1; text-overflow: ellipsis; margin-top: 8px; }
