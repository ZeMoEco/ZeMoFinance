	.section-total { font-size: 15px; font-weight: bold; color: #3b73d9; margin-left: 10px; }
	.section-action { font-size: 13px; color: #3b73d9; }
	.accounts-head { align-items: flex-end; margin-top: 22px; margin-bottom: 12px; }
	.cash-col { width: 53%; overflow: visible; }
	.debt-col { width: 42%; overflow: visible; }
	.cash-stack, .credit-stack { flex-direction: column; position: relative; overflow: visible; }
	.credit-stack { height: 240rpx; }
	.cash-account-card { background-color: #fff; border-radius: 16px; padding: 22rpx; border-width: 1px; border-color: rgba(13,77,84,0.08); box-shadow: 0 4px 12px rgba(13,77,84,0.1); }
	.cash-stack .cash-account-card { min-height: 150rpx; }
	.credit-stack .cash-account-card { min-height: 190rpx; justify-content: flex-start; }
	.credit-card { background-color: rgba(59,115,217,0.82); border-radius: 18px; box-shadow: 0 8px 22px rgba(59,115,217,0.24); }
	.account-top { justify-content: space-between; margin-bottom: 7px; }
	.account-icon-box { width: 30px; height: 30px; border-radius: 9px; background-color: #eef2f4; justify-content: center; align-items: center; }
	.account-icon-box-credit { background-color: rgba(255,255,255,0.16); }
	.account-icon { font-size: 16px; }
	.account-tag { background-color: #eef2f4; padding: 3px 10px; border-radius: 8px; }
	.account-tag-text { font-size: 11px; color: #7a8a92; }
