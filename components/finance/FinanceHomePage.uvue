	.bill-amount { font-size: 16px; font-weight: bold; margin-bottom: 4px; }
	.bill-income { color: #52b6a5; }
	.bill-expense { color: #e85d67; }
	.bill-neutral { color: #8c98a4; }
	.empty-tip, .empty-mini { align-items: center; padding: 20px; }
	.empty-text { color: #9aa6ac; font-size: 13px; }
	.load-tip { align-items: center; padding: 10px 0 4px 0; }
	.load-tip-text { font-size: 12px; color: #9aa6ac; }
	.list-bottom-spacer { height: 90px; }
</style>
