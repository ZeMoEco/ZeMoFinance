	.tool-btn { margin-right: 8px; }
	.eye-icon, .tool-icon, .tool-sync-icon { font-size: 16px; color: #33415f; }
	.tool-icon { font-size: 14px; font-weight: bold; }
	.assets-amount { font-size: 31px; font-weight: bold; color: #243152; margin-bottom: 12px; }
	.assets-sub-row { flex: 1; }
	.assets-chip { border-radius: 10px; padding: 4px 9px; background-color: rgba(59,115,217,0.12); border-width: 1px; border-color: rgba(59,115,217,0.14); margin-right: 8px; }
	.assets-chip-text { font-size: 11px; color: #3b73d9; font-weight: bold; }
	.assets-sub-text, .card-number, .card-holder { font-size: 12px; color: #758097; }
	.card-number, .card-holder { font-weight: bold; }
