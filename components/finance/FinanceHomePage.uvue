	.bill-row { min-height: 64px; padding: 9px 12px; }
	.bill-icon-box { width: 34px; height: 34px; border-radius: 17px; background-color: rgba(245,248,251,0.74); border-width: 1px; border-color: rgba(255,255,255,0.72); justify-content: center; align-items: center; margin-right: 10px; }
	.bill-icon { font-size: 17px; }
	.bill-info { flex: 1; }
	.bill-category { font-size: 15px; font-weight: bold; color: #1b2846; margin-bottom: 4px; }
	.bill-time { font-size: 12px; color: #9aa6ac; }
