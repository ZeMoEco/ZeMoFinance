<template>
	<scroll-view class="finance-home-scroll" scroll-y="true" lower-threshold="80" @scrolltolower="$emit('load-more')">
		<view class="assets-card">
			<view class="assets-head">
				<view>
					<text class="assets-label">{{ cardMetricTitle }}</text>
					<text class="assets-bank-name">泽墨账</text>
				</view>
				<view class="assets-tools">
					<view class="tool-btn" @click="$emit('calendar')">
						<text class="tool-icon">日</text>
					</view>
					<view class="eye-btn" @click="$emit('toggle-hide')">
						<text class="eye-icon">{{ hideAmount ? '🙈' : '👁' }}</text>
					</view>
				</view>
			</view>
			<text class="assets-amount">¥ {{ hideAmount ? '****' : cardMetricValue.toFixed(2) }}</text>
			<view class="assets-sub-row">
				<view class="assets-chip">
					<text class="assets-chip-text">{{ cardMetricBadge }}</text>
				</view>
				<text class="assets-sub-text">{{ cardMetricDesc }}</text>
			</view>
			<view class="card-bottom-row">
				<text class="card-number">****  {{ cardMetricTail }}</text>
				<text class="card-holder">{{ cardMetricHolder }}</text>
			</view>
		</view>

		<view class="section-head">
			<text class="section-title">最近账单</text>
			<text class="section-action" @click="$emit('record')">记一笔</text>
		</view>

		<view class="bill-day" v-for="group in billGroups" :key="group.dayKey">
			<view class="bill-day-head">
				<view class="bill-day-title-row">
					<text class="bill-day-title">{{ group.title }}</text>
					<text class="bill-week">{{ group.weekday }}</text>
				</view>
				<view class="bill-day-summary">
					<text class="bill-summary-label">收</text>
					<text class="bill-summary-income">{{ group.income.toFixed(2) }}</text>
					<text class="bill-summary-label bill-summary-gap">支</text>
					<text class="bill-summary-expense">{{ group.expense.toFixed(2) }}</text>
				</view>
			</view>

			<view class="bill-list-card">
				<view class="bill-row" v-for="bill in group.bills" :key="bill.id" @click.stop="openBillEditor(bill.id)" @tap.stop="openBillEditor(bill.id)">
					<view class="bill-icon-box">
						<text class="bill-icon">{{ getCategoryIcon(bill.category) }}</text>
					</view>
					<view class="bill-info">
						<text class="bill-category">{{ getCategoryText(bill.category) }}</text>
						<text class="bill-time">{{ getBillSubtitle(bill) }}</text>
					</view>
					<view class="bill-right">
						<text class="bill-amount" :class="getBillAmountClass(bill)">{{ getBillAmountText(bill) }}</text>
						<text class="bill-account">{{ getAccountText(bill) }}</text>
					</view>
				</view>
			</view>
		</view>

		<view class="empty-tip" v-if="recentBills.length == 0">
			<text class="empty-text">暂无账单，去记一笔</text>
		</view>
		<view class="load-tip" v-if="recentBills.length > 0">
			<text class="load-tip-text">{{ billLoading ? '加载中...' : (billHasMore ? '上拉加载更多' : '没有更多账单') }}</text>
		</view>
		<view class="list-bottom-spacer"></view>
	</scroll-view>
</template>

<script lang="uts">
	import { TransactionMount } from '@/services/biz/FinanceBiz.uts';
	import { AppDialogApi } from '@/components/sys/AppDialogApi.uts';

	type BillDayGroup = {
		dayKey: string;
		title: string;
		weekday: string;
		income: number;
		expense: number;
		bills: TransactionMount[];
	};

	type BillDaySummary = {
		dayKey: string;
		income: number;
		expense: number;
	};

	export default {
		emits: ['toggle-hide', 'record', 'load-more', 'calendar'],
		props: {
			recentBills: { type: Array as PropType<TransactionMount[]>, default: () => [] as TransactionMount[] },
			billDaySummaries: { type: Array as PropType<BillDaySummary[]>, default: () => [] as BillDaySummary[] },
			hideAmount: { type: Boolean, default: false },
			cardMetricTitle: { type: String, default: '' },
			cardMetricValue: { type: Number, default: 0.0 },
			cardMetricBadge: { type: String, default: '' },
			cardMetricDesc: { type: String, default: '' },
			cardMetricTail: { type: String, default: '' },
			cardMetricHolder: { type: String, default: '' },
			billLoading: { type: Boolean, default: false },
			billHasMore: { type: Boolean, default: true }
		},
		data() {
			return {
				noop: 0
			}
		},
		computed: {
			billGroups() : BillDayGroup[] {
				const groups = [] as BillDayGroup[];
				this.recentBills.forEach((bill) => {
					const d = new Date(bill.transaction_time);
					const dayStart = new Date(d.getFullYear(), d.getMonth(), d.getDate()).getTime();
					const dayKey = dayStart.toString();
					let target = null as BillDayGroup | null;
					for (let i = 0; i < groups.length; i++) {
						if (groups[i].dayKey == dayKey) {
							target = groups[i];
							break;
						}
					}
					if (target == null) {
						target = {
							dayKey: dayKey,
							title: this.formatDayTitle(dayStart),
							weekday: this.formatWeekday(dayStart),
							income: 0.0,
							expense: 0.0,
							bills: [] as TransactionMount[]
						} as BillDayGroup;
						groups.push(target);
					}
					target.bills.push(bill);
					if (this.isBillIncludedInFlow(bill)) {
						const amount = Math.abs(bill.amount);
						if (bill.type == 'income') {
							target.income += amount;
						} else {
							target.expense += amount;
						}
					}
				});
				for (let i = 0; i < groups.length; i++) {
					const summary = this.findBillDaySummary(groups[i].dayKey);
					if (summary != null) {
						groups[i].income = summary.income;
						groups[i].expense = summary.expense;
					}
				}
				return groups;
			}
		},
		methods: {
			findBillDaySummary(dayKey : string) : BillDaySummary | null {
				for (let i = 0; i < this.billDaySummaries.length; i++) {
					if (this.billDaySummaries[i].dayKey == dayKey) return this.billDaySummaries[i];
				}
				return null;
			},
			isBillIncludedInFlow(bill : TransactionMount) : boolean {
				const raw = bill.properties == null ? '' : bill.properties!.toString();
				if (raw.trim() == '') return true;
				try {
					const props = JSON.parse(raw) as any;
					const flag = props['include_in_flow'];
					if (flag == null) return true;
					const text = flag.toString();
					return text != 'false' && text != '0';
				} catch (_e) {
					return true;
				}
			},
			getCategoryIcon(c : string | null) : string {
				if (c == null) return '💸';
				if (c.includes('餐')) return '🍽';
				if (c.includes('购')) return '🛍';
				if (c.includes('交通')) return '🚗';
				if (c.includes('工资')) return '💵';
				if (c.includes('转')) return '💳';
				if (c.includes('信贷') || c.includes('债') || c.includes('分期')) return '💳';
				if (c.includes('其他')) return '🔗';
				return '💸';
			},
			getCategoryText(c : string | null) : string {
				if (c == null || c == '') return '账单';
				return c;
			},
			formatDayTitle(dayStart : number) : string {
				const target = new Date(dayStart);
				const now = new Date();
				const today = new Date(now.getFullYear(), now.getMonth(), now.getDate()).getTime();
				const diffDays = Math.round((today - dayStart) / 86400000);
				if (diffDays == 0) return '今天';
				if (diffDays == 1) return '昨天';
				const month = (target.getMonth() + 1).toString().padStart(2, '0');
				const day = target.getDate().toString().padStart(2, '0');
				return `${month}月${day}日`;
			},
			formatWeekday(dayStart : number) : string {
				const labels = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'] as string[];
				return labels[new Date(dayStart).getDay()];
			},
			getBillSubtitle(bill : TransactionMount) : string {
				const desc = bill.description ?? '';
				if (!this.isBillIncludedInFlow(bill)) return desc.trim() != '' ? `不计入收支 · ${desc}` : '不计入收支';
				if (desc.trim() != '') return desc;
				return this.getAccountText(bill);
			},
			getBillAmountText(bill : TransactionMount) : string {
				const prefix = this.isBillIncludedInFlow(bill) ? (bill.type == 'income' ? '+' : '-') : '';
				return `${prefix}${Math.abs(bill.amount).toFixed(2)}`;
			},
			getBillAmountClass(bill : TransactionMount) : string {
				if (!this.isBillIncludedInFlow(bill)) return 'bill-neutral';
				return bill.type == 'income' ? 'bill-income' : 'bill-expense';
			},
			getAccountText(bill : TransactionMount) : string {
				const name = bill.account_name ?? '';
				if (name.trim() != '') return name;
				return bill.account_id;
			},
			openBillEditor(billId : string) {
				AppDialogApi.openFinanceRecordForEdit(billId);
			}
		}
	}
</script>

<style>
	.finance-home-scroll { flex: 1; width: 100%; height: 100%; padding: 10px 14px 0 14px; box-sizing: border-box; border-radius: 10px; overflow: hidden; }
	.assets-card { flex-direction: column; background-color: rgba(255,255,255,0.62); border-radius: 18px; padding: 18px; margin: 0 0 10px 0; aspect-ratio: 1.586; border-width: 1px; border-color: rgba(255,255,255,0.72); box-shadow: 0 14px 32px rgba(44,62,92,0.12); }
	.assets-head, .assets-tools, .assets-sub-row, .card-bottom-row, .section-head, .section-title-row, .accounts-head, .account-columns, .account-top, .bill-day-head, .bill-day-title-row, .bill-day-summary, .bill-row { flex-direction: row; }
	.assets-head, .card-bottom-row, .section-head, .accounts-head { justify-content: space-between; }
	.assets-head { align-items: flex-start; margin-bottom: 24px; }
	.assets-tools, .assets-sub-row, .section-head, .account-top, .bill-day-head, .bill-row { align-items: center; }
