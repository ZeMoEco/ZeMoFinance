	.stack-dot-active { width: 16px; background-color: #3b73d9; }
	.invest-scroll { width: 100%; height: 220rpx; flex-direction: row; white-space: nowrap; }
	.invest-card { min-width: 200rpx; height: 200rpx; flex-shrink: 0; background-color: rgba(255,255,255,0.95); border-radius: 28rpx; padding: 24rpx; margin-right: 20rpx; justify-content: center; box-shadow: 0 3px 10px rgba(0,0,0,0.03); }
	.invest-icon-box { width: 72rpx; height: 72rpx; border-radius: 20rpx; background-color: #eef6f5; justify-content: center; align-items: center; margin-bottom: 16rpx; }
	.invest-icon { font-size: 20px; }
