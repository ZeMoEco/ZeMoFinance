<template>
  <view v-if="visible" class="perm-mask">
    <view class="perm-panel" :class="{ 'perm-panel-open': panelOpen }" @touchstart="onPanelTouchStart" @touchmove="onPanelTouchMove" @touchend="onPanelTouchEnd" @touchcancel="onPanelTouchEnd">
      <!-- Decorator Handle -->
      <view class="perm-grabber-wrap">
        <view class="perm-grabber"></view>
      </view>
      
      <!-- Header -->
      <view class="perm-header">
        <text class="perm-title">权限申请</text>
        <view class="perm-close-btn" @click="onClose">
            <text class="perm-close-icon">✕</text>
        </view>
      </view>
      
      <!-- Description -->
      <view class="perm-desc-box">
        <text class="perm-desc-text">Zemo 需要以下权限来保证番茄钟与提醒功能的正常运行。</text>
      </view>
      
      <!-- List -->
      <view class="perm-list">
        <view v-for="item in states" :key="item.key" class="perm-item">
          <!-- Icon placeholder or status indicator could go here -->
          <view class="perm-item-content">
            <text class="perm-item-title">{{ getLabel(item.key).title }}</text>
            <text class="perm-item-sub">{{ getLabel(item.key).desc }}</text>
          </view>
          
          <view class="perm-item-action">
            <view v-if="item.granted" class="perm-status-ok">
                <text class="perm-status-text">已开启</text>
            </view>
            <button v-else class="perm-action-btn" @click="onRequest(item.key)">
                去开启
            </button>
          </view>
        </view>
      </view>
      
      <!-- Footer -->
      <view class="perm-footer">
        <button class="perm-main-btn" @click="onClose">我了解了</button>
      </view> 
    </view>
  </view>
</template>

<script lang="uts">
import { Permission, type PermissionKey, type PermissionState } from '@/services/sys/Permission.uts'

type PermissionLabel = { title: string; desc: string }

export default {
  name: 'PermissionModal',
  emits: ['update:show', 'close'],
  props: {
    show: { type: Boolean, default: false },
  permissions: {
    type: Array,
    default: function (): PermissionKey[] {
      return ['overlay', 'notification', 'exactAlarm'] as PermissionKey[]
    }
  }
  },
  data() {
    return {
      visible: false,
	  states: [] as PermissionState[],
    panelOpen: false,
	  dragStartY: -1,
	  dragCurrentY: -1
    }
  },
  watch: {
    show(val: boolean) {
    if (val) {
      this.startOpen()
      this.refresh()
    } else {
      this.startClose()
    }
    }
  },
  mounted() {
    if (this.show) {
      this.startOpen()
      this.refresh()
    }
  },
  methods: {
    startOpen() {
      this.visible = true
      this.panelOpen = false
      // 下一帧再打开，触发从下往上的过渡
      setTimeout(() => {
        this.panelOpen = true
      }, 16)
    },
    startClose() {
      if (!this.visible) return
      this.panelOpen = false
      // 等过渡结束再隐藏
      setTimeout(() => {
        this.visible = false
      }, 240)
    },
    getLabel(key: PermissionKey): PermissionLabel {
      switch (key) {
        case 'overlay': return { title: '悬浮窗权限', desc: '用于后台/锁屏显示提醒界面' }
        case 'notification': return { title: '消息通知权限', desc: '用于显示通知提醒' }
        case 'exactAlarm': return { title: '精确闹钟/重要任务提醒', desc: '用于准时触发提醒闹钟' }
        case 'backgroundPopup': return { title: '后台弹出界面', desc: '用于从后台拉起提醒界面' }
        case 'autoStart': return { title: '自启动/后台运行', desc: '用于保证APP在后台持续运行' }
      }
      return { title: '未知权限', desc: '该功能需要额外权限' }
    },
    async refresh() {
		const keys = (this.permissions as any) as PermissionKey[]
		this.states = Permission.statuses(keys)
    },
    async onRequest(key: PermissionKey) {
      await Permission.ensure(key)
      this.refresh()
    },
    onPanelTouchStart(e: TouchEvent) {
      try {
        const y = e.touches[0].clientY as number
        this.dragStartY = y
        this.dragCurrentY = y
      } catch (_e) {
        this.dragStartY = -1
        this.dragCurrentY = -1
      }
    },
    onPanelTouchMove(e: TouchEvent) {
      try {
        if (this.dragStartY < 0) return
        this.dragCurrentY = e.touches[0].clientY as number
      } catch (_e) { }
    },
    onPanelTouchEnd(_e: TouchEvent) {
      try {
        if (this.dragStartY < 0) return
        const endY = this.dragCurrentY
        const delta = endY - this.dragStartY
        this.dragStartY = -1
        this.dragCurrentY = -1
        if (delta > 80) this.onClose()
      } catch (_e) {
        this.dragStartY = -1
        this.dragCurrentY = -1
      }
    },
    onClose() {
    // 由 v-model 控制 show，先通知外部，再执行关闭过渡（兜底）
    this.$emit('update:show', false)
    this.$emit('close')
    this.startClose()
    }
  }
}
</script>

<style scoped>
.perm-mask { 
    position: fixed; 
    left: 0; 
    top: 0; 
    right: 0; 
    bottom: 0; 
    background-color: rgba(0,0,0,0.6); 
    display: flex; 
    flex-direction: column;
    justify-content: flex-end; 
    align-items: center; 
    z-index: 10000;
}
.perm-panel { 
    width: 100%; 
    background-color: #ffffff; 
    border-top-left-radius: 32rpx; 
    border-top-right-radius: 32rpx; 
    padding: 20rpx 40rpx 60rpx 40rpx; 
    /* Important: Handles safe area at bottom */
    padding-bottom: 60px; /* Fallback for calc env */
    
    transform: translateY(100%); 
    transition-property: transform;
    transition-duration: 0.3s;
    transition-timing-function: cubic-bezier(0.25, 1, 0.5, 1);
}
.perm-panel-open { 
    transform: translateY(0); 
}

