    display: flex; 
    flex-direction: row;
    align-items: center; 
    justify-content: space-between; 
    margin-bottom: 30rpx; 
}
.perm-title { 
    font-size: 40rpx; 
    font-weight: bold; 
    color: #1A1A1A; 
}
.perm-close-btn {
    width: 60rpx;
    height: 60rpx;
    background-color: #F5F5F5;
    border-radius: 30rpx;
    display: flex;
    justify-content: center;
    align-items: center;
}
.perm-close-icon { 
    font-size: 28rpx; 
    color: #666666; 
    font-weight: bold;
}

.perm-desc-box {
    margin-bottom: 40rpx;
}
.perm-desc-text { 
    color: #666666; 
    font-size: 28rpx; 
    line-height: 1.6; 
}

.perm-list { 
    display: flex;
    flex-direction: column;
}

.perm-item { 
    display: flex; 
    flex-direction: row;
    justify-content: space-between; 
    align-items: center; 
    padding: 30rpx 0; 
    border-bottom-width: 1px;
    border-bottom-style: solid;
    border-bottom-color: #F0F0F0;
}
/* Last item no border */
/* .perm-item:last-child { border-bottom: none; } */

.perm-item-content { 
    flex: 1; 
    display: flex; 
    flex-direction: column; 
    justify-content: center;
    margin-right: 20rpx;
}
.perm-item-title { 
    font-size: 32rpx; 
    color: #1A1A1A; 
    font-weight: bold; 
    margin-bottom: 8rpx; 
}
.perm-item-sub { 
    font-size: 24rpx; 
    color: #999999; 
}

.perm-item-action { 
    display: flex;
    align-items: center;
    justify-content: flex-end;
}
.perm-status-ok { 
    background-color: #F0F9EB; 
    padding: 10rpx 20rpx;
    border-radius: 12rpx;
}
.perm-status-text {
    color: #67C23A;
    font-size: 24rpx;
    font-weight: bold;
}

.perm-action-btn { 
    /* Overriding default button styles */
    background-color: #1A1A1A; 
    color: #FFFFFF; 
    border-radius: 40rpx; 
    padding: 0 30rpx;
    height: 64rpx;
    line-height: 64rpx;
    font-size: 26rpx; 
    font-weight: bold;
    margin: 0; 
    border-width: 0;
}

.perm-footer { 
    margin-top: 50rpx; 
}
.perm-main-btn { 
    width: 100%; 
    height: 96rpx;
    line-height: 96rpx;
    background-color: #000000; 
    color: #FFFFFF; 
    border-radius: 24rpx; 
    font-size: 32rpx; 
    font-weight: bold; 
    border-width: 0;
}
/* Adding active state for buttons */
.perm-main-btn:active {
    opacity: 0.8;
}
.perm-action-btn:active {
    opacity: 0.8;
}
</style>
