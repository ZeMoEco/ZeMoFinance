  width: 74px;
  height: 8px;
  border-radius: 6px;
  background-color: #d7dce4;
}

.cooking-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding-left: 24px;
  padding-right: 24px;
  padding-top: 6px;
  padding-bottom: 10px;
  position: relative;
}

.cooking-title {
  font-size: 20px;
  font-weight: 700;
  color: #0e1b36;
}

.cooking-close {
  position: absolute;
  right: 24px;
  top: 2px;
  width: 44px;
  height: 44px;
  border-radius: 22px;
  background-color: #e5e8ef;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cooking-close-text {
  font-size: 20px;
  color: #77808f;
}

.cooking-scroll {
  padding-left: 24px;
  padding-right: 24px;
  max-height: 1000rpx;
}

