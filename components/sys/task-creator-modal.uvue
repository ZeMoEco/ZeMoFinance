  color: #1f4f8d;
  font-weight: 600;
}

.selected-strip {
  margin-top: 4px;
  margin-bottom: 8px;
}

.selected-strip-title {
  font-size: 15px;
  color: #5f6a7c;
  margin-bottom: 8px;
}

.selected-strip-scroll {
  height: 34px;
  white-space: nowrap;
}

.selected-chip {
  display: inline-flex;
  flex-direction: row;
  height: 30px;
  padding-left: 12px;
  padding-right: 12px;
  border-radius: 15px;
  background-color: #d6e4f2;
  margin-right: 8px;
  align-items: center;
  justify-content: center;
}

.selected-chip-text {
  font-size: 14px;
  color: #214b6b;
}

.cooking-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 36px;
  padding-bottom: 36px;
}

.cooking-empty-text {
  font-size: 16px;
  color: #98a2b3;
}

.recipe-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 10px;
}

.recipe-card {
  width: 48.5%;
  margin-bottom: 16px;
  position: relative;
  opacity: 0.8;
  display: flex;
  flex-direction: column;
}

.recipe-card-active {
  opacity: 1;
}

.recipe-cover {
  width: 100%;
  height: 180px;
  border-radius: 18px;
  background-color: #e7ebf2;
}

.recipe-check {
  position: absolute;
  right: 10px;
  top: 10px;
  width: 32px;
  height: 32px;
