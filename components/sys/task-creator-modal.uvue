  width: 100%;
  border-radius: 34px 34px 0 0;
  background-color: #ffffff;
  box-shadow: 0 -8px 24px rgba(30, 48, 64, 0.12);
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

.cooking-handle-wrap {
  align-items: center;
  padding-top: 12px;
  padding-bottom: 6px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

