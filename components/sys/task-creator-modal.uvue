  margin-right: 10px;
}

.meal-chip-active {
  background-color: #0b6678;
}

.meal-chip-text {
  font-size: 18px;
  color: #243147;
  font-weight: 500;
}

.meal-chip-text-active {
  color: #ffffff;
  font-weight: 700;
}

.cooking-time-hint {
  font-size: 14px;
  color: #9aa3b2;
  margin-top: 10px;
}

.cooking-section-head {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-top: 22px;
}

.cooking-section-title {
  font-size: 20px;
  font-weight: 700;
  color: #0e1b36;
}

.cooking-section-link {
  font-size: 16px;
  font-weight: 600;
  color: #0b6678;
}

.recipe-tab-row {
